<%- include('partials/header') %>

<style>
  /* Import specific overrides */
  .drop-zone {
    border: 2px dashed var(--blue-300); border-radius: 16px; padding: 48px 24px; text-align: center;
    cursor: pointer; transition: all .2s; background: var(--blue-50);
  }
  .drop-zone:hover, .drop-zone.drag { border-color: var(--blue-500); background: var(--blue-100); }
  .drop-zone input[type=file] { display: none; }
  
  .preview-table { width: 100%; border-collapse: collapse; font-size: 12px; }
  .preview-table th { background: var(--slate-50); color: var(--slate-600); padding: 10px 12px; text-align: left; font-weight: 600; white-space: nowrap; border-bottom: 1px solid var(--border); }
  .preview-table td { padding: 8px 12px; border-bottom: 1px solid var(--slate-100); color: var(--slate-600); white-space: nowrap; }
  .preview-table tr.has-error td { background: #fef2f2; }
  .preview-table tr:hover td { background: var(--blue-50); }
  
  .step-bar { display: flex; margin-bottom: 32px; }
  .step { flex: 1; padding: 12px 16px; font-size: 13px; font-weight: 600; color: var(--slate-400); border-bottom: 2px solid var(--slate-200); text-align: center; }
  .step.active { color: var(--blue-600); border-bottom-color: var(--blue-600); }
  .step.done { color: #16a34a; border-bottom-color: #16a34a; }
  
  .field-tag { display: inline-block; background: var(--blue-50); border: 1px solid var(--blue-200); border-radius: 6px; padding: 3px 8px; font-size: 11px; font-weight:600; color: var(--blue-700); margin: 2px; }
</style>

<div style="max-width:1100px;margin:0 auto">

  <!-- Header -->
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:16px">
    <div>
      <h1 class="page-title">Import Data Alumni</h1>
      <p class="page-sub">Upload file CSV/Excel untuk menambahkan data alumni secara massal</p>
    </div>
    <a href="/data" class="btn btn-ghost">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      Kembali ke Data Master
    </a>
  </div>

  <!-- Alert -->
  <% if (alertType === 'import-success') { %>
  <div class="g-alert g-alert-success">
    ✅ Import berhasil! <strong><%= imported %></strong> alumni ditambahkan, <strong><%= skipped %></strong> baris dilewati.
  </div>
  <% } %>
  <% if (alertType === 'no-file') { %>
  <div class="g-alert g-alert-error">⚠️ Tidak ada file yang dipilih.</div>
  <% } %>
  <% if (alertType === 'no-data') { %>
  <div class="g-alert g-alert-error">⚠️ Sesi preview telah kedaluwarsa. Silakan upload ulang.</div>
  <% } %>

  <!-- Step bar -->
  <div class="step-bar">
    <div class="step <%= preview ? 'done' : 'active' %>">① Upload File</div>
    <div class="step <%= preview ? 'active' : '' %>">② Preview & Validasi</div>
    <div class="step">③ Konfirmasi Import</div>
  </div>

  <% if (!preview) { %>
  <!-- ── STEP 1: UPLOAD ── -->
  <div class="g-card g-card-p">
    <h2 style="font-family:'Plus Jakarta Sans',sans-serif;color:var(--slate-800);font-size:17px;font-weight:700;margin:0 0 20px">Upload File</h2>

    <form action="/import/preview" method="POST" enctype="multipart/form-data" id="uploadForm">
      <div class="drop-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
        <input type="file" id="fileInput" name="file" accept=".xlsx,.xls,.csv" onchange="handleFile(this)">
        <div style="font-size:40px;margin-bottom:12px">📂</div>
        <div style="color:var(--slate-700);font-weight:700;font-size:16px;margin-bottom:8px" id="dropLabel">Klik atau drag & drop file di sini</div>
        <div style="color:var(--slate-500);font-size:13px">Format yang didukung: .xlsx, .xls, .csv — Maks 10 MB</div>
        <div style="color:var(--blue-600);font-weight:600;font-size:13px;margin-top:12px;display:none" id="fileName"></div>
      </div>

      <div style="margin-top:20px">
        <p style="color:var(--slate-500);font-size:13px;font-weight:600;margin-bottom:10px">Kolom yang dikenali (minimal: <strong style="color:var(--blue-600)">Nama Lulusan</strong>):</p>
        <div>
          <% ['Nama Lulusan','NIM','Tahun Masuk','Tanggal Lulus','Fakultas','Program Studi','Email','No HP','LinkedIn','Instagram','Facebook','TikTok','Tempat Kerja','Alamat Kerja','Posisi','Jenis Pekerjaan'].forEach(f => { %>
          <span class="field-tag"><%= f %></span>
          <% }) %>
        </div>
      </div>

      <div style="margin-top:24px">
        <button type="submit" class="btn btn-primary" id="uploadBtn" disabled>
          🔍 Preview & Validasi
        </button>
      </div>
    </form>
  </div>

  <% } else { %>
  <!-- ── STEP 2: PREVIEW ── -->
  <div class="g-card g-card-p" style="margin-bottom:20px">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px">
      <div>
        <h2 style="font-family:'Plus Jakarta Sans',sans-serif;color:var(--slate-800);font-size:17px;font-weight:700;margin:0">Preview Data</h2>
        <p style="color:var(--slate-500);font-size:13px;margin:4px 0 0">
          Total <strong style="color:var(--slate-800)"><%= totalRows %></strong> baris ditemukan
          <% if (errors.length > 0) { %> · <strong style="color:#dc2626"><%= errors.length %></strong> error ditemukan<% } %>
          <% if (errors.length === 0) { %> · <span style="color:#16a34a;font-weight:600">✅ Tidak ada error</span><% } %>
        </p>
      </div>
      <a href="/import" class="btn btn-danger">✕ Batal & Upload Ulang</a>
    </div>

    <!-- Error list -->
    <% if (errors.length > 0) { %>
    <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:12px;padding:16px;margin-bottom:20px">
      <p style="color:#dc2626;font-weight:600;margin:0 0 10px">⚠️ Baris Bermasalah:</p>
      <% errors.slice(0,10).forEach(e => { %>
      <div style="font-size:12.5px;color:#ef4444;margin:4px 0">Baris <%= e.row %> — <strong><%= e.field %></strong>: <%= e.msg %></div>
      <% }) %>
      <% if (errors.length > 10) { %><div style="font-size:12px;color:var(--slate-500);margin-top:6px">...dan <%= errors.length - 10 %> error lainnya.</div><% } %>
    </div>
    <% } %>

    <!-- Preview table -->
    <div style="overflow-x:auto;border-radius:10px;border:1px solid var(--border)">
      <table class="preview-table">
        <thead>
          <tr><th>#</th><% columns.forEach(c => { %><th><%= c %></th><% }) %></tr>
        </thead>
        <tbody>
          <% preview.forEach((row, i) => { %>
          <tr><td><%= i + 1 %></td><% columns.forEach(c => { %><td><%= row[c] ?? '' %></td><% }) %></tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <p style="color:var(--slate-500);font-size:12px;margin-top:10px">Menampilkan 20 baris pertama dari <%= totalRows %> baris total.</p>
  </div>

  <!-- Confirm button -->
  <% if (errors.length === 0 || true) { %>
  <div class="g-card g-card-p" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px">
    <div>
      <p style="color:var(--slate-800);font-weight:700;margin:0">Siap mengimport <strong><%= totalRows %></strong> alumni?</p>
      <p style="color:var(--slate-500);font-size:13px;margin:4px 0 0">Status akan diklasifikasikan otomatis berdasarkan scoring kelengkapan data.</p>
    </div>
    <form action="/import/confirm" method="POST">
      <button type="submit" class="btn btn-success" id="confirmBtn" onclick="this.innerHTML='⏳ Mengimport...';this.disabled=true">
        ✅ Konfirmasi Import
      </button>
    </form>
  </div>
  <% } %>
  <% } %>

</div>

<script>
  function handleFile(input) {
    const file = input.files[0];
    if (!file) return;
    document.getElementById('fileName').textContent = '📄 ' + file.name + ' (' + (file.size / 1024).toFixed(1) + ' KB)';
    document.getElementById('fileName').style.display = 'block';
    document.getElementById('dropLabel').textContent = 'File dipilih';
    document.getElementById('uploadBtn').disabled = false;
  }
  // Drag & drop
  const dz = document.getElementById('dropZone');
  if (dz) {
    dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('drag'); });
    dz.addEventListener('dragleave', () => dz.classList.remove('drag'));
    dz.addEventListener('drop', e => {
      e.preventDefault(); dz.classList.remove('drag');
      const fi = document.getElementById('fileInput');
      fi.files = e.dataTransfer.files;
      handleFile(fi);
    });
  }
  document.getElementById('uploadBtn')?.addEventListener('click', function() {
    this.innerHTML = '⏳ Memproses...'; this.disabled = true;
  });
</script>

<%- include('partials/footer') %>
