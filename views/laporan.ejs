<%- include('partials/header') %>

<div class="px-4 py-8 sm:px-0">
    <div class="mb-8 border-b border-slate-200/60 pb-5">
        <h1 class="text-3xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-slate-900 to-indigo-800 font-outfit tracking-tight">Dashboard & Laporan Statistik</h1>
        <p class="mt-2 text-sm text-slate-500 font-medium">
            Hasil agregat analitik dari data pelacakan alumni publik. Diperbarui otomatis setiap 60 detik.
        </p>
    </div>

    <!-- KPI Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-6 gap-4 mb-10">
        <!-- Total -->
        <div class="col-span-2 lg:col-span-2 bg-white/70 backdrop-blur-xl border border-slate-200/60 rounded-2xl shadow-lg p-6 flex items-center gap-5">
            <div class="w-14 h-14 rounded-2xl bg-slate-100 flex items-center justify-center text-2xl flex-shrink-0">🎓</div>
            <div>
                <div class="text-xs text-slate-400 font-bold uppercase tracking-widest">Total Database</div>
                <div class="text-4xl font-extrabold text-slate-800 font-outfit mt-1"><%= stats.total.toLocaleString('id-ID') %></div>
                <div class="text-xs text-slate-400 mt-0.5">Alumni terdaftar</div>
            </div>
        </div>
        <!-- Teridentifikasi -->
        <div class="col-span-1 bg-emerald-50 border border-emerald-100 rounded-2xl shadow-sm p-5 text-center">
            <div class="text-xs text-emerald-600 font-bold uppercase tracking-wider">Teridentifikasi</div>
            <div class="text-3xl font-black text-emerald-700 font-outfit mt-2"><%= stats.teridentifikasi %></div>
            <div class="text-xs text-emerald-500 mt-1">≥ 70% match</div>
        </div>
        <!-- Perlu Verifikasi -->
        <div class="col-span-1 bg-amber-50 border border-amber-100 rounded-2xl shadow-sm p-5 text-center">
            <div class="text-xs text-amber-600 font-bold uppercase tracking-wider">Perlu Verifikasi</div>
            <div class="text-3xl font-black text-amber-700 font-outfit mt-2"><%= stats.perluVerifikasi %></div>
            <div class="text-xs text-amber-500 mt-1">40–69% match</div>
        </div>
        <!-- Belum Ditemukan -->
        <div class="col-span-1 bg-rose-50 border border-rose-100 rounded-2xl shadow-sm p-5 text-center">
            <div class="text-xs text-rose-600 font-bold uppercase tracking-wider">Belum Ditemukan</div>
            <div class="text-3xl font-black text-rose-700 font-outfit mt-2"><%= stats.belumDitemukan %></div>
            <div class="text-xs text-rose-500 mt-1">< 40% match</div>
        </div>
        <!-- Bekerja -->
        <div class="col-span-1 bg-sky-50 border border-sky-100 rounded-2xl shadow-sm p-5 text-center">
            <div class="text-xs text-sky-600 font-bold uppercase tracking-wider">Bekerja</div>
            <div class="text-3xl font-black text-sky-700 font-outfit mt-2"><%= stats.bekerja %></div>
            <div class="text-xs text-sky-500 mt-1">PNS / Swasta / BUMN</div>
        </div>
    </div>

    <!-- Charts Row 1 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <!-- Doughnut — Status -->
        <div class="bg-white/70 backdrop-blur-xl border border-slate-200/60 shadow-lg rounded-2xl p-6">
            <h3 class="text-base font-bold text-slate-800 mb-1 font-outfit">Distribusi Status Pelacakan</h3>
            <p class="text-xs text-slate-400 mb-4">Proporsi status seluruh data alumni</p>
            <div class="max-w-xs mx-auto">
                <canvas id="statusChart"></canvas>
            </div>
        </div>

        <!-- Bar — Tahun Lulus -->
        <div class="bg-white/70 backdrop-blur-xl border border-slate-200/60 shadow-lg rounded-2xl p-6">
            <h3 class="text-base font-bold text-slate-800 mb-1 font-outfit">Distribusi Tahun Lulus</h3>
            <p class="text-xs text-slate-400 mb-4">Jumlah alumni per angkatan kelulusan</p>
            <canvas id="tahunChart"></canvas>
        </div>
    </div>

    <!-- Charts Row 2 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <!-- Bar — Prodi -->
        <div class="col-span-1 lg:col-span-2 bg-white/70 backdrop-blur-xl border border-slate-200/60 shadow-lg rounded-2xl p-6">
            <h3 class="text-base font-bold text-slate-800 mb-1 font-outfit">Top 10 Program Studi</h3>
            <p class="text-xs text-slate-400 mb-4">Jumlah alumni terbanyak per program studi</p>
            <canvas id="prodiChart" style="max-height:280px"></canvas>
        </div>
    </div>

    <!-- Priority Callout -->
    <div class="bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-200/60 rounded-2xl p-6 flex gap-4 items-start">
        <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center">
            <svg class="h-5 w-5 text-amber-600" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
        </div>
        <div>
            <p class="text-sm text-amber-900 font-bold">Prioritas HRD</p>
            <p class="text-sm text-amber-800 mt-1 leading-relaxed">
                Admin / HRD disarankan fokus memverifikasi <span class="bg-amber-200/60 px-2 py-0.5 rounded font-bold"><%= stats.perluVerifikasi %> entri</span>
                berstatus <em>"Perlu Verifikasi Manual"</em>. Entri ini memiliki skor kecocokan 40–69% dan memerlukan diskresi manusia.
            </p>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const COLORS = {
        green:  { bg: 'rgba(34,197,94,0.8)',  border: 'rgba(34,197,94,1)' },
        yellow: { bg: 'rgba(234,179,8,0.8)',  border: 'rgba(234,179,8,1)' },
        red:    { bg: 'rgba(239,68,68,0.8)',  border: 'rgba(239,68,68,1)' },
        blue:   { bg: 'rgba(99,102,241,0.8)', border: 'rgba(99,102,241,1)' },
    };

    // ── Doughnut: Status ──────────────────────────────────────────────────
    new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
            labels: ['Teridentifikasi', 'Perlu Verifikasi', 'Belum Ditemukan'],
            datasets: [{
                data: [<%= stats.teridentifikasi %>, <%= stats.perluVerifikasi %>, <%= stats.belumDitemukan %>],
                backgroundColor: [COLORS.green.bg, COLORS.yellow.bg, COLORS.red.bg],
                borderColor:     [COLORS.green.border, COLORS.yellow.border, COLORS.red.border],
                borderWidth: 2, hoverOffset: 6,
            }]
        },
        options: { responsive: true, cutout: '65%', plugins: { legend: { position: 'bottom' } } }
    });

    // ── Bar: Tahun Lulus ─────────────────────────────────────────────────
    const tahunData = <%- JSON.stringify(tahunChart) %>;
    new Chart(document.getElementById('tahunChart'), {
        type: 'bar',
        data: {
            labels: tahunData.map(d => d[0]),
            datasets: [{
                label: 'Jumlah Alumni',
                data: tahunData.map(d => d[1]),
                backgroundColor: COLORS.blue.bg,
                borderColor: COLORS.blue.border,
                borderWidth: 1, borderRadius: 6,
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false } },
                y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: 'rgba(0,0,0,0.04)' } },
            }
        }
    });

    // ── Bar: Prodi ────────────────────────────────────────────────────────
    const prodiData = <%- JSON.stringify(prodiChart) %>;
    const prodiColors = prodiData.map((_, i) => `hsl(${220 + i * 18}, 80%, ${60 + (i % 3) * 5}%)`);
    new Chart(document.getElementById('prodiChart'), {
        type: 'bar',
        data: {
            labels: prodiData.map(d => d[0]),
            datasets: [{
                label: 'Jumlah Alumni',
                data: prodiData.map(d => d[1]),
                backgroundColor: prodiColors.map(c => c + 'cc'),
                borderColor: prodiColors,
                borderWidth: 1, borderRadius: 6,
            }]
        },
        options: {
            responsive: true,
            indexAxis: 'y',   // horizontal bar
            plugins: { legend: { display: false } },
            scales: {
                x: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: 'rgba(0,0,0,0.04)' } },
                y: { grid: { display: false } },
            }
        }
    });
</script>

<%- include('partials/footer') %>
