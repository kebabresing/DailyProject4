<%- include('partials/header') %>

<div class="px-4 py-8 sm:px-0">
    <div class="mb-8 border-b border-slate-200/60 pb-5">
        <h1 class="text-3xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-slate-900 to-indigo-800 font-outfit tracking-tight">Dashboard & Laporan Statistik</h1>
        <p class="mt-2 text-sm text-slate-500 font-medium">
            Berikut adalah hasil agregat analitik dari data pelacakan alumni publik oleh bot scheduler.
        </p>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
        <div class="bg-white/60 backdrop-blur-xl border border-white/60 rounded-2xl shadow-xl shadow-indigo-100/50 p-6 relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                <svg class="w-12 h-12 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
            </div>
            <h3 class="text-slate-500 text-xs font-bold uppercase tracking-widest font-outfit">Total Database</h3>
            <div class="mt-3 flex items-baseline">
                <span class="text-4xl font-extrabold text-slate-800 font-outfit"><%= stats.total %></span>
                <span class="ml-2 text-sm text-slate-500 font-medium">Orang</span>
            </div>
        </div>

        <div class="bg-white/60 backdrop-blur-xl border border-emerald-100 rounded-2xl shadow-xl shadow-emerald-100/50 p-6 relative overflow-hidden group">
            <h3 class="text-emerald-600 text-xs font-bold uppercase tracking-widest font-outfit">Teridentifikasi Publik</h3>
            <div class="mt-3 flex items-baseline">
                <span class="text-4xl font-extrabold text-emerald-700 font-outfit"><%= stats.teridentifikasi %></span>
                <span class="ml-2 text-xs font-bold text-emerald-500 bg-emerald-50 px-2 py-0.5 rounded-full">Kecocokan &ge; 70%</span>
            </div>
        </div>

        <div class="bg-white/60 backdrop-blur-xl border border-amber-100 rounded-2xl shadow-xl shadow-amber-100/50 p-6 relative overflow-hidden group">
            <h3 class="text-amber-600 text-xs font-bold uppercase tracking-widest font-outfit">Perlu Verifikasi</h3>
            <div class="mt-3 flex flex-col items-start xl:flex-row xl:items-baseline gap-2">
                <span class="text-4xl font-extrabold text-amber-700 font-outfit"><%= stats.perluVerifikasi %></span>
                <span class="text-xs font-bold text-amber-600 bg-amber-50 px-2 py-0.5 rounded-full">Ambigu / Minim Bio</span>
            </div>
        </div>

        <div class="bg-white/60 backdrop-blur-xl border border-rose-100 rounded-2xl shadow-xl shadow-rose-100/50 p-6 relative overflow-hidden group">
            <h3 class="text-rose-600 text-xs font-bold uppercase tracking-widest font-outfit">Belum Ditemukan</h3>
            <div class="mt-3 flex flex-col items-start xl:flex-row xl:items-baseline gap-2">
                <span class="text-4xl font-extrabold text-rose-700 font-outfit"><%= stats.belumDitemukan %></span>
                <span class="text-xs font-bold text-rose-600 bg-rose-50 px-2 py-0.5 rounded-full">Data Tdk Tersedia</span>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
        <!-- Doughnut Chart (Status Distribusi) -->
        <div class="bg-white/60 backdrop-blur-xl border border-white/60 shadow-2xl shadow-indigo-100/50 rounded-2xl p-8 flex flex-col items-center ring-1 ring-slate-200/50">
            <h3 class="text-xl font-bold text-slate-800 mb-6 w-full text-left font-outfit">Distribusi Status Pelacakan</h3>
            <div class="w-full max-w-sm relative">
                <canvas id="statusChart"></canvas>
            </div>
        </div>

        <!-- Info Card Khusus / Legend -->
        <div class="bg-white/60 backdrop-blur-xl border border-white/60 shadow-2xl shadow-indigo-100/50 rounded-2xl p-8 ring-1 ring-slate-200/50">
            <h3 class="text-xl font-bold text-slate-800 mb-6 w-full text-left font-outfit">Prioritas Penanganan HRD</h3>
            <div class="bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-200/60 shadow-inner rounded-xl p-5 mb-5 ring-1 ring-inset ring-amber-100">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <svg class="h-6 w-6 text-amber-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm text-amber-800 font-bold leading-relaxed">
                            Admin / HRD disarankan fokus memverifikasi <span class="bg-amber-200/60 px-2 py-0.5 rounded text-amber-900"><%= stats.perluVerifikasi %> entri data</span> berstatus "Perlu Verifikasi Manual" di layar Data Master.
                        </p>
                    </div>
                </div>
            </div>
            <p class="text-slate-600 text-sm/relaxed text-justify font-medium">
                Sesuai definisi Use Case Diagram "Verifikasi Manual", entitas bersatus kewaspadaan kuning (interval skor 40% - 69%) umumnya timbul akibat kemiripan <i>Identity Signals</i> yang ambigu. Contoh klasiknya: Menemukan profil pekerja di LinkedIn yang memiliki nama sama persis, namun profil yang bersangkutan menolak mencantumkan asal lulusan di riwayat pendidikannya. Sistem kita sangat butuh intervensi & diskresi kebijaksanaan HRD setempat.
            </p>
        </div>
    </div>
</div>

<!-- Chart JS -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Inisialisasi Chart dari data EJS 
    const ctx = document.getElementById('statusChart').getContext('2d');
    const statusChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: ['Teridentifikasi', 'Perlu Verifikasi', 'Belum Ditemukan'],
            datasets: [{
                data: [<%= stats.teridentifikasi %>, <%= stats.perluVerifikasi %>, <%= stats.belumDitemukan %>],
                backgroundColor: [
                    'rgba(34, 197, 94, 0.8)',   // Green
                    'rgba(234, 179, 8, 0.8)',    // Yellow
                    'rgba(239, 68, 68, 0.8)'     // Red
                ],
                borderColor: [
                    'rgba(34, 197, 94, 1)',   
                    'rgba(234, 179, 8, 1)',    
                    'rgba(239, 68, 68, 1)'     
                ],
                borderWidth: 1,
                hoverOffset: 4
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'bottom',
                }
            }
        }
    });
</script>

<%- include('partials/footer') %>
