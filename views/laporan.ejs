<%- include('partials/header') %>

<style>
  /* ── Laporan Dashboard Specific Styles ── */
  .bento { display: grid; gap: 16px; }
  .bento-6 { grid-template-columns: repeat(6, 1fr); }
  .bento-3 { grid-template-columns: repeat(3, 1fr); }
  .bento-2 { grid-template-columns: repeat(2, 1fr); }

  /* KPI cards */
  .kpi-icon {
    width: 44px; height: 44px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-bottom: 12px;
  }
  .kpi-icon svg { color: currentColor; }
  .kpi-val {
    font-family: 'Plus Jakarta Sans', sans-serif; font-size: 30px; font-weight: 800;
    color: var(--slate-800); line-height: 1; letter-spacing: -1px;
    animation: countUp .5s ease both;
  }
  .kpi-label { font-size: 11.5px; font-weight: 700; color: var(--slate-500); text-transform: uppercase; letter-spacing: .5px; margin-top: 6px; }
  .kpi-sub   { font-size: 11px; color: var(--muted); margin-top: 3px; }

  /* Accent strips */
  .accent-blue   { border-top: 3px solid var(--blue-500); }
  .accent-green  { border-top: 3px solid #22c55e; }
  .accent-amber  { border-top: 3px solid #f59e0b; }
  .accent-red    { border-top: 3px solid #ef4444; }

  /* Hero card */
  .hero-card {
    background: linear-gradient(135deg, var(--blue-50) 0%, #fff 100%);
    border: 1px solid var(--blue-200);
  }
  .hero-card:hover { border-color: var(--blue-400); }

  /* Chart container */
  .chart-wrap { position: relative; height: 240px; }
  .chart-title { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 14.5px; font-weight: 700; color: var(--slate-800); margin: 0 0 4px; }
  .chart-sub   { font-size: 11.5px; color: var(--muted); margin: 0 0 20px; }

  /* Top company list */
  .top-item {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 0; border-bottom: 1px solid var(--slate-100);
  }
  .top-item:last-child { border-bottom: none; padding-bottom: 0; }
  .top-rank {
    width: 26px; height: 26px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; flex-shrink: 0;
    background: var(--slate-100); color: var(--slate-600);
  }
  .top-rank.gold   { background: #fef3c7; color: #d97706; }
  .top-rank.silver { background: #f1f5f9; color: #64748b; }
  .top-rank.bronze { background: #ffedd5; color: #c2410c; }

  /* Gradient text */
  .grad-text {
    background: linear-gradient(90deg, var(--blue-600), var(--blue-400));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }

  @keyframes countUp { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }

  /* Responsive Grid */
  @media(max-width: 1024px) {
    .bento-6 { grid-template-columns: repeat(3, 1fr); }
    .hero-card { grid-column: span 3; }
    .bento-3 { grid-template-columns: repeat(2, 1fr); }
    .bento-2 { grid-template-columns: 1fr; }
  }
  @media(max-width: 768px) {
    .bento-6 { grid-template-columns: repeat(2, 1fr); }
    .hero-card { grid-column: span 2; }
    .bento-3 { grid-template-columns: 1fr; }
  }
  @media(max-width: 480px) {
    .bento-6 { grid-template-columns: 1fr 1fr; }
    .kpi-val { font-size: 24px; }
  }
</style>

<!-- Page header -->
<div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:24px">
  <div>
    <h1 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:26px;font-weight:800;color:var(--slate-800);margin:0;letter-spacing:-.5px">
      Laporan <span class="grad-text">Alumni UMM</span>
    </h1>
    <p style="color:var(--muted);font-size:13px;margin:4px 0 0">Data diperbarui otomatis · <%= new Date().toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric'}) %></p>
  </div>
  <div style="display:flex;gap:10px;flex-wrap:wrap">
    <a href="/data" class="btn btn-secondary">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
      Data Master
    </a>
    <a href="/export" class="btn btn-primary">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
      Export Excel
    </a>
  </div>
</div>

<!-- ══ ROW 1: KPI Bento ══ -->
<div class="bento bento-6" style="margin-bottom:16px">

  <!-- Hero: Total -->
  <div class="g-card hero-card" style="grid-column:span 2;display:flex;flex-direction:column;justify-content:space-between;padding:24px">
    <div>
      <div class="kpi-icon" style="background:var(--blue-100);color:var(--blue-600)">
        <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
      </div>
      <div class="kpi-val"><%= stats.total.toLocaleString('id-ID') %></div>
      <div class="kpi-label">Total Terdaftar</div>
    </div>
    <div style="margin-top:20px">
      <div style="font-size:11px;color:var(--slate-500);margin-bottom:6px;display:flex;justify-content:space-between">
        <span>Kelengkapan Data</span>
        <span style="font-weight:700"><%= stats.total > 0 ? Math.round((stats.teridentifikasi/stats.total)*100) : 0 %>%</span>
      </div>
      <div class="g-prog">
        <div class="g-prog-fill" style="width:<%= stats.total > 0 ? Math.round((stats.teridentifikasi/stats.total)*100) : 0 %>%"></div>
      </div>
    </div>
  </div>

  <!-- Teridentifikasi -->
  <div class="g-card accent-green g-card-p">
    <div class="kpi-icon" style="background:#dcfce7;color:#16a34a">
      <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
    </div>
    <div class="kpi-val" style="color:#16a34a"><%= stats.teridentifikasi.toLocaleString('id-ID') %></div>
    <div class="kpi-label">Teridentifikasi</div>
    <div class="kpi-sub">Skor ≥ 70%</div>
  </div>

  <!-- Perlu Verifikasi -->
  <div class="g-card accent-amber g-card-p">
    <div class="kpi-icon" style="background:#fef3c7;color:#d97706">
      <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
    </div>
    <div class="kpi-val" style="color:#d97706"><%= stats.perluVerifikasi.toLocaleString('id-ID') %></div>
    <div class="kpi-label">Verifikasi</div>
    <div class="kpi-sub">Skor 40-69%</div>
  </div>

  <!-- Belum Ditemukan -->
  <div class="g-card accent-red g-card-p">
    <div class="kpi-icon" style="background:#fee2e2;color:#dc2626">
      <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
    </div>
    <div class="kpi-val" style="color:#dc2626"><%= stats.belumDitemukan.toLocaleString('id-ID') %></div>
    <div class="kpi-label">Belum Ditemukan</div>
    <div class="kpi-sub">Skor < 40%</div>
  </div>

  <!-- Bekerja -->
  <div class="g-card accent-blue g-card-p">
    <div class="kpi-icon" style="background:var(--blue-100);color:var(--blue-600)">
      <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
    </div>
    <div class="kpi-val" style="color:var(--blue-600)"><%= (stats.swasta + stats.pns).toLocaleString('id-ID') %></div>
    <div class="kpi-label">Pekerja Aktif</div>
    <div class="kpi-sub">PNS / Swasta</div>
  </div>

</div>

<!-- ══ ROW 2: Charts ══ -->
<div class="bento bento-2" style="margin-bottom:16px">
  
  <!-- Doughnut Chart -->
  <div class="g-card g-card-p">
    <p class="chart-title">Status Kelengkapan</p>
    <p class="chart-sub">Proporsi data alumni berdasarkan kelengkapan</p>
    <div class="chart-wrap">
      <canvas id="statusChart"></canvas>
    </div>
  </div>

  <!-- Bar Chart Tahun -->
  <div class="g-card g-card-p">
    <p class="chart-title">Tren Lulusan</p>
    <p class="chart-sub">Jumlah alumni per angkatan kelulusan</p>
    <div class="chart-wrap">
      <canvas id="tahunChart"></canvas>
    </div>
  </div>

</div>

<!-- ══ ROW 3: Charts & Lists ══ -->
<div class="bento bento-3" style="margin-bottom:16px">

  <!-- Top 10 Prodi -->
  <div class="g-card g-card-p">
    <p class="chart-title">Top Program Studi</p>
    <p class="chart-sub">Alumni terbanyak per prodi</p>
    <div class="chart-wrap" style="height:260px">
      <canvas id="prodiChart"></canvas>
    </div>
  </div>

  <!-- Jenis Pekerjaan -->
  <div class="g-card g-card-p">
    <p class="chart-title">Kategori Pekerjaan</p>
    <p class="chart-sub">Komposisi profesi alumni</p>
    <div class="chart-wrap" style="height:260px">
      <canvas id="pekChart"></canvas>
    </div>
  </div>

  <!-- Top Companies -->
  <div class="g-card g-card-p" style="display:flex;flex-direction:column">
    <p class="chart-title">Top Perusahaan</p>
    <p class="chart-sub">Tempat kerja terbanyak</p>
    <div style="flex:1;overflow-y:auto;padding-right:4px">
      <% if (topCompanies && topCompanies.length > 0) { %>
        <% topCompanies.forEach((c, idx) => { %>
        <div class="top-item">
          <div class="top-rank <%= idx===0?'gold':idx===1?'silver':idx===2?'bronze':'' %>"><%= idx+1 %></div>
          <div style="flex:1;min-width:0">
            <div style="font-size:13px;font-weight:600;color:var(--slate-700);white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= c.tempatKerja %></div>
          </div>
          <div style="font-size:12px;font-weight:700;color:var(--blue-600);background:var(--blue-50);padding:2px 8px;border-radius:6px"><%= c.jumlah %></div>
        </div>
        <% }) %>
      <% } else { %>
        <div style="text-align:center;padding:40px 0;color:var(--slate-400);font-size:13px">Belum ada data perusahaan</div>
      <% } %>
    </div>
  </div>

</div>

<!-- ══ ROW 4: Calls to Action ══ -->
<div class="bento bento-2">

  <div class="g-card" style="padding:22px;background:var(--blue-50);border-color:var(--blue-200);display:flex;gap:16px;align-items:flex-start">
    <div style="background:#fff;width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;color:var(--blue-600);box-shadow:0 2px 8px rgba(59,130,246,.15);flex-shrink:0">
      <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
    </div>
    <div>
      <div style="font-size:14.5px;font-weight:700;color:var(--blue-800);margin-bottom:4px">Prioritas Verifikasi</div>
      <div style="font-size:13px;color:var(--blue-700);line-height:1.5;margin-bottom:12px">
        Ada <strong style="color:var(--blue-900)"><%= stats.perluVerifikasi.toLocaleString('id-ID') %></strong> alumni dengan skor 40–69% yang menunggu verifikasi admin.
      </div>
      <a href="/pipeline" class="btn btn-primary btn-sm">Buka Pipeline</a>
    </div>
  </div>

  <div class="g-card g-card-p" style="display:flex;flex-direction:column;justify-content:center">
    <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)">
      <span style="font-size:13px;color:var(--slate-500)">Status Database</span>
      <span class="badge badge-green"><span class="live-dot" style="width:6px;height:6px;margin-right:4px"></span> Supabase Online</span>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)">
      <span style="font-size:13px;color:var(--slate-500)">Wirausaha</span>
      <span style="font-size:13.5px;font-weight:700;color:var(--slate-700)"><%= stats.wirausaha.toLocaleString('id-ID') %> alumni</span>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0">
      <span style="font-size:13px;color:var(--slate-500)">Sistem Cache</span>
      <span class="badge badge-blue">Aktif (60s)</span>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  Chart.defaults.color = '#64748b';
  Chart.defaults.borderColor = '#f1f5f9';
  Chart.defaults.font.family = "'Inter', sans-serif";

  // ── Doughnut: Status
  new Chart(document.getElementById('statusChart'), {
    type: 'doughnut',
    data: {
      labels: ['Teridentifikasi', 'Verifikasi', 'Belum Ditemukan'],
      datasets: [{
        data: [<%= stats.teridentifikasi %>, <%= stats.perluVerifikasi %>, <%= stats.belumDitemukan %>],
        backgroundColor: ['#22c55e', '#f59e0b', '#ef4444'],
        borderWidth: 0, hoverOffset: 4,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, cutout: '70%',
      plugins: { legend: { position: 'bottom', labels: { padding: 16, usePointStyle: true, font: { size: 11 } } } }
    }
  });

  // ── Bar: Tahun Lulus
  const tahunData = <%- JSON.stringify(tahunChart) %>;
  new Chart(document.getElementById('tahunChart'), {
    type: 'bar',
    data: {
      labels: tahunData.map(d => d[0]),
      datasets: [{
        label: 'Alumni',
        data: tahunData.map(d => d[1]),
        backgroundColor: '#60a5fa', borderRadius: 4, barPercentage: 0.7,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 10 }, maxRotation: 45 } },
        y: { beginAtZero: true, border: { display: false } }
      }
    }
  });

  // ── Horizontal Bar: Prodi
  const prodiData = <%- JSON.stringify(prodiChart) %>;
  new Chart(document.getElementById('prodiChart'), {
    type: 'bar',
    data: {
      labels: prodiData.map(d => d[0]),
      datasets: [{
        label: 'Alumni',
        data: prodiData.map(d => d[1]),
        backgroundColor: '#818cf8', borderRadius: 4, barPercentage: 0.6,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false, indexAxis: 'y',
      plugins: { legend: { display: false } },
      scales: {
        x: { beginAtZero: true, border: { display: false } },
        y: { grid: { display: false }, ticks: { font: { size: 10 } } }
      }
    }
  });

  // ── Pie: Jenis Pekerjaan
  const pekData = <%- JSON.stringify(pekChart || []) %>;
  if (pekData.length > 0 && pekData.some(d => d[1] > 0)) {
    new Chart(document.getElementById('pekChart'), {
      type: 'pie',
      data: {
        labels: pekData.map(d => d[0]),
        datasets: [{
          data: pekData.map(d => d[1]),
          backgroundColor: ['#3b82f6', '#06b6d4', '#10b981', '#f59e0b', '#ef4444'],
          borderWidth: 0, hoverOffset: 4,
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { padding: 12, usePointStyle: true, font: { size: 10 } } } }
      }
    });
  }
</script>

<%- include('partials/footer') %>
