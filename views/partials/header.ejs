<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Alumni Tracker UMM</title>
    <meta name="description" content="Sistem Pelacakan Alumni Universitas Muhammadiyah Malang berbasis data publik.">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3, .font-outfit { font-family: 'Outfit', sans-serif; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

        /* Page transition skeleton */
        #page-loader {
            position: fixed; top: 0; left: 0; right: 0; height: 3px; z-index: 9999;
            background: linear-gradient(90deg, #6366f1, #8b5cf6, #6366f1);
            background-size: 200% 100%;
            animation: loading-bar 1.2s linear infinite;
            opacity: 0; transition: opacity 0.2s;
        }
        #page-loader.active { opacity: 1; }
        @keyframes loading-bar {
            0%   { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* Mobile menu smooth open/close */
        #mobile-menu {
            transition: max-height 0.3s ease, opacity 0.3s ease;
            max-height: 0; overflow: hidden; opacity: 0;
        }
        #mobile-menu.open { max-height: 400px; opacity: 1; }
    </style>
</head>
<body class="text-slate-700 bg-gradient-to-br from-slate-50 via-white to-indigo-50/50 flex flex-col min-h-screen selection:bg-indigo-500/30">

    <!-- Progress bar loader -->
    <div id="page-loader"></div>

    <nav class="bg-white/70 backdrop-blur-2xl border-b border-slate-200/80 shadow-[0_2px_16px_rgba(0,0,0,0.07)] w-full sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <!-- Logo -->
                <a href="/" class="flex items-center group">
                    <img src="/logo.png" alt="Alumni Tracker UMM" class="h-14 w-auto group-hover:scale-105 transition-transform duration-300">
                </a>

                <!-- Desktop Nav -->
                <div class="hidden sm:flex items-center space-x-1">
                    <%
                    const navLinks = [
                        { href: '/',        label: 'Laporan' },
                        { href: '/data',    label: 'Data Master' },
                        { href: '/pipeline',label: '🔍 Pipeline' },
                        { href: '/tracker', label: '🤖 Tracker', highlight: true },
                    ];
                    navLinks.forEach(link => {
                        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
                    %>
                        <a href="<%= link.href %>"
                           class="px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200
                           <%  if (isActive && link.highlight) { %>
                               text-violet-700 bg-violet-100 ring-1 ring-inset ring-violet-300
                           <%  } else if (isActive) { %>
                               text-indigo-700 bg-indigo-50 ring-1 ring-inset ring-indigo-200
                           <%  } else if (link.highlight) { %>
                               text-violet-600 bg-violet-50 hover:bg-violet-100 ring-1 ring-inset ring-violet-200
                           <%  } else { %>
                               text-slate-600 hover:text-indigo-600 hover:bg-indigo-50/60
                           <%  } %>">
                            <%= link.label %>
                        </a>
                    <% }); %>

                    <% if (user) { %>
                    <div class="flex items-center gap-3 ml-4 pl-4 border-l border-slate-200">
                        <div class="text-right hidden md:block">
                            <div class="text-xs text-slate-400 font-medium leading-none">Login sebagai</div>
                            <div class="text-sm font-bold text-slate-700 mt-0.5"><%= user.namaLengkap %></div>
                        </div>
                        <div class="h-8 w-8 rounded-full bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center text-white text-sm font-bold shadow-sm">
                            <%= user.namaLengkap.charAt(0).toUpperCase() %>
                        </div>
                        <form action="/logout" method="POST">
                            <button type="submit" class="bg-red-50 hover:bg-red-100 text-red-600 text-xs font-bold px-3 py-2 rounded-lg transition-all duration-200 border border-red-100 hover:border-red-200">
                                🚪 Keluar
                            </button>
                        </form>
                    </div>
                    <% } %>
                </div>

                <!-- Mobile Hamburger Button -->
                <button id="mobile-menu-btn" class="sm:hidden flex items-center justify-center w-10 h-10 rounded-xl text-slate-600 hover:bg-slate-100 transition-colors" aria-label="Toggle menu">
                    <svg id="hamburger-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                    <svg id="close-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="sm:hidden border-t border-slate-100 bg-white/95 backdrop-blur-xl px-4">
            <div class="py-3 space-y-1">
                <%
                const mobileLinks = [
                    { href: '/',        label: 'Laporan Statistik', icon: '📊' },
                    { href: '/data',    label: 'Data Master',       icon: '🗃️' },
                    { href: '/pipeline',label: 'Pipeline',          icon: '🔍' },
                    { href: '/tracker', label: 'Intelligent Tracker', icon: '🤖' },
                ];
                mobileLinks.forEach(link => {
                    const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
                %>
                    <a href="<%= link.href %>"
                       class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold transition-colors
                       <%= isActive ? 'bg-indigo-50 text-indigo-700' : 'text-slate-700 hover:bg-slate-50' %>">
                        <span class="text-base"><%= link.icon %></span>
                        <%= link.label %>
                        <% if (isActive) { %>
                        <span class="ml-auto w-1.5 h-1.5 rounded-full bg-indigo-500"></span>
                        <% } %>
                    </a>
                <% }); %>

                <% if (user) { %>
                <div class="border-t border-slate-100 pt-3 mt-3">
                    <div class="flex items-center justify-between px-3 py-2">
                        <div>
                            <div class="text-xs text-slate-400">Login sebagai</div>
                            <div class="text-sm font-bold text-slate-800"><%= user.namaLengkap %></div>
                        </div>
                        <form action="/logout" method="POST">
                            <button type="submit" class="bg-red-50 text-red-600 text-xs font-bold px-3 py-2 rounded-lg border border-red-100">
                                🚪 Keluar
                            </button>
                        </form>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </nav>

    <main class="flex-grow w-full max-w-7xl mx-auto">

<script>
    // Mobile menu toggle
    const btn  = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const hIcon = document.getElementById('hamburger-icon');
    const xIcon = document.getElementById('close-icon');
    btn.addEventListener('click', () => {
        const open = menu.classList.toggle('open');
        hIcon.classList.toggle('hidden', open);
        xIcon.classList.toggle('hidden', !open);
    });

    // Page transition loader
    const loader = document.getElementById('page-loader');
    document.querySelectorAll('a[href]:not([target="_blank"]):not([href^="#"]):not([href^="javascript"])').forEach(a => {
        a.addEventListener('click', () => {
            loader.classList.add('active');
        });
    });
    window.addEventListener('pageshow', () => loader.classList.remove('active'));
</script>
