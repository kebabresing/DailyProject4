<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Alumni Tracker UMM</title>
  <meta name="description" content="Alumni Tracker UMM — Platform pelacakan dan manajemen alumni Universitas Muhammadiyah Malang.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    /* ═══════════════════════════════════════
       ALUMNI TRACKER — Soft Blue & White
    ═══════════════════════════════════════ */
    :root {
      --sidebar-w: 240px;
      --blue-50:  #eff6ff;
      --blue-100: #dbeafe;
      --blue-200: #bfdbfe;
      --blue-400: #60a5fa;
      --blue-500: #3b82f6;
      --blue-600: #2563eb;
      --blue-700: #1d4ed8;
      --slate-50: #f8fafc;
      --slate-100:#f1f5f9;
      --slate-200:#e2e8f0;
      --slate-300:#cbd5e1;
      --slate-400:#94a3b8;
      --slate-600:#475569;
      --slate-700:#334155;
      --slate-800:#1e293b;
      --slate-900:#0f172a;
      --text:     #1e293b;
      --muted:    #64748b;
      --border:   #e2e8f0;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      min-height: 100vh;
      background: #f0f5ff;
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      display: flex;
    }

    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 99px; }

    h1,h2,h3,.f-jakarta { font-family: 'Plus Jakarta Sans', sans-serif; }

    /* ══════════ SIDEBAR ══════════ */
    .sidebar {
      width: var(--sidebar-w);
      min-height: 100vh;
      background: #fff;
      border-right: 1px solid var(--border);
      box-shadow: 2px 0 16px rgba(59,130,246,.07);
      display: flex;
      flex-direction: column;
      position: fixed;
      left: 0; top: 0;
      z-index: 50;
      transition: transform .28s cubic-bezier(.4,0,.2,1);
      overflow-y: auto;
    }

    .sidebar-logo {
      padding: 22px 20px 18px;
      display: flex; align-items: center; gap: 10px;
      border-bottom: 1px solid var(--border);
      text-decoration: none; flex-shrink: 0;
    }
    .sidebar-logo img {
      height: 34px; width: 34px; object-fit: contain; flex-shrink: 0;
    }
    .sidebar-logo-text {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px; font-weight: 700; color: var(--slate-800); line-height: 1.3;
    }
    .sidebar-logo-sub { font-size: 9.5px; color: var(--muted); font-weight: 500; }

    .sidebar-section { padding: 14px 12px 4px; flex-shrink: 0; }
    .sidebar-section-label {
      font-size: 9.5px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 1px; color: var(--slate-300);
      padding: 0 10px 8px;
    }

    .sidebar-link {
      display: flex; align-items: center; gap: 10px;
      padding: 9px 12px; border-radius: 10px;
      font-size: 13.5px; font-weight: 500; color: var(--slate-600);
      text-decoration: none; transition: all .16s ease;
      margin-bottom: 2px; position: relative;
    }
    .sidebar-link svg { flex-shrink: 0; opacity: .65; transition: opacity .16s; }
    .sidebar-link:hover {
      background: var(--blue-50); color: var(--blue-600);
    }
    .sidebar-link:hover svg { opacity: 1; }
    .sidebar-link.active {
      background: var(--blue-50); color: var(--blue-600); font-weight: 600;
    }
    .sidebar-link.active svg { opacity: 1; }
    .sidebar-link.active::before {
      content: ''; position: absolute;
      left: 0; top: 50%; transform: translateY(-50%);
      width: 3px; height: 20px;
      background: var(--blue-500); border-radius: 0 3px 3px 0;
    }

    .sidebar-footer {
      margin-top: auto; padding: 14px 12px;
      border-top: 1px solid var(--border); flex-shrink: 0;
    }
    .user-panel {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px; border-radius: 12px;
      background: var(--blue-50); border: 1px solid var(--blue-100);
    }
    .user-avatar {
      width: 32px; height: 32px; border-radius: 9px; flex-shrink: 0;
      background: linear-gradient(135deg, #2563eb, #3b82f6);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700;
      font-size: 13px; color: #fff;
    }
    .user-name { font-size: 12.5px; font-weight: 600; color: var(--slate-700); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .user-role { font-size: 10px; color: var(--muted); }
    .logout-btn {
      padding: 6px 10px; border-radius: 8px; flex-shrink: 0;
      background: transparent; border: 1px solid var(--border);
      color: var(--muted); font-size: 11.5px; font-weight: 600;
      cursor: pointer; transition: all .16s;
      font-family: 'Inter', sans-serif;
    }
    .logout-btn:hover { background: #fee2e2; border-color: #fecaca; color: #dc2626; }

    /* Mobile toggle */
    .sidebar-toggle {
      display: none; position: fixed;
      top: 12px; left: 12px; z-index: 200;
      width: 38px; height: 38px; border-radius: 10px;
      background: #fff; border: 1px solid var(--border);
      box-shadow: 0 2px 8px rgba(0,0,0,.08);
      color: var(--slate-700); cursor: pointer;
      align-items: center; justify-content: center;
      transition: all .16s;
    }
    .sidebar-toggle:hover { background: var(--blue-50); border-color: var(--blue-200); color: var(--blue-600); }
    .sidebar-toggle svg { pointer-events: none; }

    .sidebar-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(15,23,42,.35); backdrop-filter: blur(3px);
      z-index: 40;
    }
    .sidebar-overlay.show { display: block; }

    /* ══════════ MAIN AREA ══════════ */
    .main-wrap {
      margin-left: var(--sidebar-w);
      min-height: 100vh; flex: 1;
      display: flex; flex-direction: column;
    }

    .topbar {
      height: 56px; padding: 0 28px;
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(255,255,255,.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      position: sticky; top: 0; z-index: 30; flex-shrink: 0;
    }
    .topbar-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 15px; font-weight: 700; color: var(--slate-800);
    }
    .topbar-sub { font-size: 11.5px; color: var(--muted); margin-top: 1px; }
    .topbar-right { display: flex; align-items: center; gap: 10px; }

    .page-content { flex: 1; padding: 28px; }

    /* ══════════ GLOBAL COMPONENTS ══════════ */

    /* Cards */
    .g-card {
      background: #fff; border: 1px solid var(--border);
      border-radius: 16px;
      box-shadow: 0 1px 4px rgba(15,23,42,.06), 0 4px 16px rgba(59,130,246,.04);
      transition: box-shadow .2s, transform .2s;
      position: relative; overflow: hidden;
    }
    .g-card:hover {
      box-shadow: 0 4px 20px rgba(15,23,42,.1), 0 8px 32px rgba(59,130,246,.08);
      transform: translateY(-1px);
    }
    .g-card-p { padding: 22px 24px; }

    /* Glass card variant */
    .g-card-glass {
      background: rgba(255,255,255,.7);
      border: 1px solid rgba(255,255,255,.9);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(59,130,246,.1);
    }

    /* Buttons — no emoji */
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 9px 18px; border-radius: 9px;
      font-size: 13px; font-weight: 600;
      text-decoration: none; cursor: pointer; border: none;
      transition: all .18s; font-family: 'Inter', sans-serif;
      white-space: nowrap; letter-spacing: .1px;
    }
    .btn-primary {
      background: var(--blue-600); color: #fff;
      box-shadow: 0 2px 8px rgba(37,99,235,.3);
    }
    .btn-primary:hover { background: var(--blue-700); box-shadow: 0 4px 16px rgba(37,99,235,.4); transform: translateY(-1px); }
    .btn-primary:active { transform: translateY(0); }
    .btn-secondary {
      background: var(--blue-50); color: var(--blue-600);
      border: 1px solid var(--blue-200);
    }
    .btn-secondary:hover { background: var(--blue-100); }
    .btn-ghost {
      background: transparent; color: var(--slate-600);
      border: 1px solid var(--border);
    }
    .btn-ghost:hover { background: var(--slate-100); color: var(--slate-700); }
    .btn-danger {
      background: #fff5f5; color: #dc2626;
      border: 1px solid #fecaca;
    }
    .btn-danger:hover { background: #fee2e2; }
    .btn-success {
      background: #f0fdf4; color: #16a34a;
      border: 1px solid #bbf7d0;
    }
    .btn-success:hover { background: #dcfce7; }
    .btn-sm { padding: 7px 14px; font-size: 12px; border-radius: 8px; }
    .btn-xs { padding: 5px 10px; font-size: 11.5px; border-radius: 7px; }

    /* Badges */
    .badge { display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:99px;font-size:11px;font-weight:600; }
    .badge-green  { background:#f0fdf4;color:#15803d;border:1px solid #bbf7d0; }
    .badge-amber  { background:#fffbeb;color:#b45309;border:1px solid #fde68a; }
    .badge-red    { background:#fff5f5;color:#dc2626;border:1px solid #fecaca; }
    .badge-blue   { background:var(--blue-50);color:var(--blue-700);border:1px solid var(--blue-200); }
    .badge-slate  { background:var(--slate-100);color:var(--slate-600);border:1px solid var(--slate-200); }

    /* Form inputs */
    .g-input,.g-select,.g-textarea {
      width:100%; padding:10px 13px;
      background:#fff; border:1px solid var(--border);
      border-radius:10px; color:var(--text);
      font-size:13.5px; font-family:'Inter',sans-serif;
      transition:all .18s; outline:none;
    }
    .g-input:focus,.g-select:focus,.g-textarea:focus {
      border-color: var(--blue-400);
      box-shadow: 0 0 0 3px rgba(59,130,246,.12);
    }
    .g-input::placeholder,.g-textarea::placeholder { color:var(--slate-300); }
    .g-label { display:block;font-size:11.5px;font-weight:600;color:var(--slate-600);margin-bottom:6px; }

    /* Table */
    .g-table { width:100%;border-collapse:collapse; }
    .g-table thead th { padding:11px 16px;font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;background:var(--slate-50);border-bottom:1px solid var(--border);text-align:left;white-space:nowrap; }
    .g-table tbody td { padding:13px 16px;border-bottom:1px solid var(--slate-100);font-size:13.5px;color:var(--slate-600); }
    .g-table tbody tr { transition:background .1s; }
    .g-table tbody tr:hover td { background:var(--blue-50);color:var(--slate-700); }
    .g-table tbody tr:last-child td { border-bottom:none; }

    /* Alerts */
    .g-alert { display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:12px;font-size:13.5px;font-weight:500;margin-bottom:16px; }
    .g-alert-success { background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d; }
    .g-alert-error   { background:#fff5f5;border:1px solid #fecaca;color:#dc2626; }
    .g-alert-warn    { background:#fffbeb;border:1px solid #fde68a;color:#b45309; }
    .g-alert-info    { background:var(--blue-50);border:1px solid var(--blue-200);color:var(--blue-700); }

    /* Progress bar */
    .g-prog      { height:5px;background:var(--slate-100);border-radius:99px;overflow:hidden; }
    .g-prog-fill { height:100%;border-radius:99px;transition:width .9s cubic-bezier(.4,0,.2,1);background:linear-gradient(90deg,#3b82f6,#60a5fa); }

    /* Utilities */
    .g-divider  { height:1px;background:var(--border);margin:20px 0; }
    .g-avatar   { display:flex;align-items:center;justify-content:center;border-radius:10px;font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;flex-shrink:0;background:linear-gradient(135deg,#2563eb,#3b82f6);color:#fff; }
    .page-title { font-family:'Plus Jakarta Sans',sans-serif;font-size:22px;font-weight:800;color:var(--slate-800);letter-spacing:-.3px; }
    .page-sub   { font-size:13px;color:var(--muted);margin-top:4px; }
    .live-dot   { width:7px;height:7px;border-radius:50%;background:#22c55e;box-shadow:0 0 6px rgba(34,197,94,.5);display:inline-block;animation:pulseDot 2s infinite; }

    /* Modals */
    .g-overlay { position:fixed;inset:0;background:rgba(15,23,42,.4);backdrop-filter:blur(4px);z-index:100; }
    .g-modal   { background:#fff;border:1px solid var(--border);border-radius:18px;box-shadow:0 20px 60px rgba(15,23,42,.18);overflow:hidden; }

    /* Animations */
    @keyframes fadeUp   { from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none} }
    @keyframes pulseDot { 0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.8)} }
    .anim-in  { animation:fadeUp .3s ease both; }
    .anim-in2 { animation:fadeUp .3s .1s ease both; }
    .anim-in3 { animation:fadeUp .3s .2s ease both; }

    /* ══════════ RESPONSIVE ══════════ */
    @media (max-width: 900px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); }
      .main-wrap { margin-left: 0; }
      .sidebar-toggle { display: flex; }
      .page-content { padding: 20px 16px; }
      .topbar { padding: 0 16px 0 58px; }
      .topbar-sub { display: none; }
      footer.main-footer { margin-left: 0 !important; }
    }
    @media (max-width: 540px) {
      .page-content { padding: 16px 12px; }
    }
  </style>
</head>
<body>

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<button class="sidebar-toggle" id="sidebarToggle" aria-label="Menu">
  <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
  </svg>
</button>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
  <a href="/" class="sidebar-logo">
    <img src="/logo.png" alt="UMM" onerror="this.style.display='none'">
    <div>
      <div class="sidebar-logo-text">Alumni Tracker</div>
      <div class="sidebar-logo-sub">Universitas Muhammadiyah Malang</div>
    </div>
  </a>

  <div class="sidebar-section">
    <div class="sidebar-section-label">Navigasi</div>

    <a href="/" class="sidebar-link <% if(currentPath==='/')        {%>active<%}%>">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      Dashboard
    </a>
    <a href="/data" class="sidebar-link <% if(currentPath==='/data'){%>active<%}%>">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>
      Data Alumni
    </a>
    <a href="/pipeline" class="sidebar-link <% if(currentPath==='/pipeline'){%>active<%}%>">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Pipeline
    </a>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-section-label">Alat</div>

    <a href="/tracker" class="sidebar-link <% if(currentPath==='/tracker'){%>active<%}%>">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      AI Tracker
    </a>
    <a href="/add" class="sidebar-link">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      Tambah Alumni
    </a>
    <a href="/export" class="sidebar-link">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
      Export Excel
    </a>
    <% if (user && user.role === 'admin') { %>
    <a href="/import" class="sidebar-link <% if(currentPath==='/import'){%>active<%}%>">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
      Import Data
    </a>
    <% } %>
  </div>

  <% if (user) { %>
  <div class="sidebar-footer">
    <div class="user-panel">
      <div class="user-avatar"><%= user.namaLengkap.charAt(0).toUpperCase() %></div>
      <div style="flex:1;min-width:0">
        <div class="user-name"><%= user.namaLengkap %></div>
        <div class="user-role"><%= user.role === 'admin' ? 'Administrator' : 'Viewer' %></div>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="logout-btn">Keluar</button>
      </form>
    </div>
  </div>
  <% } %>
</aside>

<!-- MAIN -->
<div class="main-wrap">
  <div class="topbar">
    <div>
      <div class="topbar-title">
        <% if(currentPath==='/')          { %>Dashboard
        <% } else if(currentPath==='/data')     { %>Data Alumni
        <% } else if(currentPath==='/pipeline') { %>Pipeline Verifikasi
        <% } else if(currentPath==='/tracker')  { %>AI Tracker
        <% } else if(currentPath==='/import')   { %>Import Data
        <% } else { %><%= title %>
        <% } %>
      </div>
      <div class="topbar-sub">Alumni Tracker UMM &rsaquo; <%= title %></div>
    </div>
    <div class="topbar-right">
      <span style="display:flex;align-items:center;gap:5px;font-size:11.5px;color:#16a34a;font-weight:600">
        <span class="live-dot"></span>Online
      </span>
      <% if (user && user.role === 'admin') { %>
      <a href="/add" class="btn btn-primary btn-sm">+ Tambah</a>
      <% } %>
    </div>
  </div>

  <div class="page-content">
