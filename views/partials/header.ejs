<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Alumni Tracker UMM — Platform pelacakan dan manajemen alumni Universitas Muhammadiyah Malang.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --c-bg:    #060b1a;
      --c-glass: rgba(255,255,255,0.05);
      --c-border:rgba(255,255,255,0.10);
      --c-indigo:#4f46e5;
      --c-violet:#7c3aed;
      --c-cyan:  #06b6d4;
      --c-green: #22c55e;
      --c-text:  #f1f5f9;
      --c-muted: #94a3b8;
    }
    *, *::before, *::after { box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      background:
        radial-gradient(ellipse 100% 60% at 15% 0%,  rgba(79,70,229,.20) 0%, transparent 55%),
        radial-gradient(ellipse 70%  50% at 85% 100%, rgba(6,182,212,.12) 0%, transparent 50%),
        linear-gradient(160deg, #060b1a 0%, #0d1432 45%, #080f26 100%);
      background-attachment: fixed;
      color: var(--c-text);
    }
    /* Scrollbar */
    ::-webkit-scrollbar { width:5px; height:5px }
    ::-webkit-scrollbar-track { background:transparent }
    ::-webkit-scrollbar-thumb { background:rgba(255,255,255,.15); border-radius:99px }
    ::-webkit-scrollbar-thumb:hover { background:rgba(255,255,255,.25) }

    h1,h2,h3,.font-poppins { font-family:'Poppins',sans-serif }

    /* ── NAV ── */
    nav.glass-nav {
      background: rgba(6,11,26,0.65);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-bottom: 1px solid var(--c-border);
      position: sticky; top:0; z-index:50;
      box-shadow: 0 4px 24px rgba(0,0,0,.3);
    }
    .nav-inner {
      max-width:1280px; margin:0 auto; padding:0 24px;
      height:60px; display:flex; align-items:center; justify-content:space-between;
    }
    /* Logo */
    .nav-logo { display:flex; align-items:center; gap:10px; text-decoration:none }
    .nav-logo img { height:40px; width:auto; object-fit:contain; filter:drop-shadow(0 0 8px rgba(79,70,229,.4)) }
    .nav-logo-text { font-family:'Poppins',sans-serif; font-size:15px; font-weight:700; color:#fff; line-height:1.2 }
    .nav-logo-sub  { font-size:10.5px; color:var(--c-muted); font-weight:400; font-family:'Inter',sans-serif }

    /* Nav links */
    .nav-links { display:flex; align-items:center; gap:4px }
    .nav-link {
      display:flex; align-items:center; gap:6px;
      padding:7px 14px; border-radius:10px;
      font-size:13px; font-weight:600; color:var(--c-muted);
      text-decoration:none; transition:all .2s; white-space:nowrap;
      border:1px solid transparent;
    }
    .nav-link:hover {
      color:#fff; background:rgba(255,255,255,.07);
      border-color:rgba(255,255,255,.1);
    }
    .nav-link.active {
      color:#fff; background:rgba(79,70,229,.18);
      border-color:rgba(79,70,229,.35);
    }
    .nav-link.tracker-link {
      color:#a5b4fc; background:rgba(79,70,229,.12);
      border-color:rgba(79,70,229,.3);
    }
    .nav-link.tracker-link:hover {
      background:rgba(79,70,229,.22); border-color:rgba(79,70,229,.5);
      box-shadow:0 0 16px rgba(79,70,229,.2);
    }
    /* User chip */
    .user-chip {
      display:flex; align-items:center; gap:10px;
      padding:5px 5px 5px 14px;
      background:rgba(255,255,255,.05); border:1px solid var(--c-border);
      border-radius:99px; margin-left:8px;
    }
    .user-chip .uname { font-size:12.5px; font-weight:600; color:#e2e8f0 }
    .user-chip .ulab  { font-size:10px; color:var(--c-muted); line-height:1 }
    .logout-btn {
      padding:6px 14px; background:rgba(239,68,68,.12);
      border:1px solid rgba(239,68,68,.25); border-radius:99px;
      color:#fca5a5; font-size:12px; font-weight:600; cursor:pointer;
      transition:all .2s; font-family:'Inter',sans-serif;
    }
    .logout-btn:hover { background:rgba(239,68,68,.22); border-color:rgba(239,68,68,.4) }

    /* Mobile hamburger */
    .hamburger {
      display:none; flex-direction:column; gap:4px; cursor:pointer;
      padding:8px; border:none; background:none;
    }
    .hamburger span { width:20px; height:2px; background:#fff; border-radius:99px; transition:.2s }

    /* Mobile nav drawer */
    .mobile-drawer {
      display:none; flex-direction:column; gap:6px;
      padding:12px 16px; border-top:1px solid var(--c-border);
      background:rgba(6,11,26,.8); backdrop-filter:blur(20px);
    }
    .mobile-drawer.open { display:flex }
    .mobile-drawer .nav-link { width:100% }

    @media(max-width:768px) {
      .nav-links, .user-chip { display:none }
      .hamburger { display:flex }
    }
  </style>
</head>
<body>

<nav class="glass-nav" aria-label="Main navigation">
  <div class="nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Alumni Tracker UMM Home">
      <img src="/logo.png" alt="Logo UMM">
      <div>
        <div class="nav-logo-text">Alumni Tracker</div>
        <div class="nav-logo-sub">Universitas Muhammadiyah Malang</div>
      </div>
    </a>

    <!-- Desktop nav -->
    <div class="nav-links">
      <a href="/" class="nav-link <% if(currentPath==='/')          {%>active<%}%>">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        Laporan
      </a>
      <a href="/data" class="nav-link <% if(currentPath==='/data')   {%>active<%}%>">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
        Data Master
      </a>
      <a href="/pipeline" class="nav-link <% if(currentPath==='/pipeline'){%>active<%}%>">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        Pipeline
      </a>
      <a href="/tracker" class="nav-link tracker-link <% if(currentPath==='/tracker'){%>active<%}%>">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        AI Tracker
      </a>
      <% if (user && user.role === 'admin') { %>
      <a href="/import" class="nav-link <% if(currentPath==='/import'){%>active<%}%>" style="color:#34d399">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
        Import
      </a>
      <% } %>

      <% if (user) { %>
      <div class="user-chip">
        <div>
          <div class="uname"><%= user.namaLengkap %></div>
          <div class="ulab" style="<%= user.role === 'admin' ? 'color:#a5b4fc' : 'color:#94a3b8' %>"><%= user.role === 'admin' ? '👑 Admin' : '👁 Viewer' %></div>
        </div>
        <form action="/logout" method="POST" style="margin:0">
          <button type="submit" class="logout-btn">Keluar</button>
        </form>
      </div>
      <% } %>
    </div>

    <!-- Hamburger -->
    <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-drawer" id="mobileDrawer">
    <a href="/"        class="nav-link">📊 Laporan</a>
    <a href="/data"    class="nav-link">📋 Data Master</a>
    <a href="/pipeline"class="nav-link">🔍 Pipeline</a>
    <a href="/tracker" class="nav-link tracker-link">⚡ AI Tracker</a>
    <% if (user) { %>
    <form action="/logout" method="POST" style="margin-top:4px">
      <button type="submit" class="logout-btn" style="width:100%;padding:10px">🚪 Keluar</button>
    </form>
    <% } %>
  </div>
</nav>

<main style="max-width:1280px;margin:0 auto;padding:28px 24px;min-height:calc(100vh - 60px - 64px)">
