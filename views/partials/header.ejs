<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Alumni Tracker UMM</title>
  <meta name="description" content="Alumni Tracker UMM — Platform pelacakan dan manajemen alumni Universitas Muhammadiyah Malang.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    /* ════════════════════════════════════════════
       ALUMNI TRACKER — SIDEBAR LAYOUT SYSTEM
    ════════════════════════════════════════════ */
    :root {
      --sidebar-w: 248px;
      --sidebar-bg: rgba(8,13,35,0.96);
      --border: rgba(255,255,255,0.07);
      --accent: #4f46e5;
      --accent2: #7c3aed;
      --cyan: #06b6d4;
      --green: #22c55e;
      --text: #f1f5f9;
      --muted: #475569;
      --muted2: #334155;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      min-height: 100vh;
      background:
        radial-gradient(ellipse 90% 60% at 20% 0%, rgba(79,70,229,.18) 0%, transparent 50%),
        radial-gradient(ellipse 70% 50% at 85% 100%, rgba(6,182,212,.12) 0%, transparent 50%),
        linear-gradient(160deg, #060b1a 0%, #0c1230 55%, #07101f 100%);
      background-attachment: fixed;
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      display: flex;
    }

    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 99px; }

    /* ════════════ SIDEBAR ════════════ */
    .sidebar {
      width: var(--sidebar-w);
      min-height: 100vh;
      height: 100%;
      background: var(--sidebar-bg);
      border-right: 1px solid var(--border);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      display: flex;
      flex-direction: column;
      position: fixed;
      left: 0; top: 0;
      z-index: 50;
      transition: transform .28s cubic-bezier(.4,0,.2,1);
      overflow-y: auto;
      overflow-x: hidden;
    }

    /* Logo area */
    .sidebar-logo {
      padding: 24px 20px 18px;
      display: flex;
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      text-decoration: none;
    }
    .sidebar-logo img {
      height: 36px; width: 36px; object-fit: contain; flex-shrink: 0;
      filter: drop-shadow(0 0 8px rgba(79,70,229,.5));
    }
    .sidebar-logo-text { font-family: 'Poppins', sans-serif; font-size: 14.5px; font-weight: 700; color: #fff; line-height: 1.25; }
    .sidebar-logo-sub  { font-size: 9.5px; color: var(--muted2); font-weight: 500; }

    /* Nav sections */
    .sidebar-section { padding: 18px 12px 8px; flex-shrink: 0; }
    .sidebar-section-label {
      font-size: 9.5px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 1px; color: var(--muted2);
      padding: 0 10px 8px;
    }

    /* Nav links */
    .sidebar-link {
      display: flex; align-items: center; gap: 11px;
      padding: 10px 12px; border-radius: 11px;
      font-size: 13.5px; font-weight: 500; color: var(--muted);
      text-decoration: none;
      transition: all .17s ease;
      border: 1px solid transparent;
      margin-bottom: 2px;
      position: relative;
    }
    .sidebar-link .icon {
      width: 32px; height: 32px; border-radius: 9px;
      display: flex; align-items: center; justify-content: center;
      font-size: 15px; flex-shrink: 0;
      background: rgba(255,255,255,.04);
      transition: all .17s;
    }
    .sidebar-link:hover {
      color: #e2e8f0;
      background: rgba(255,255,255,.05);
      border-color: rgba(255,255,255,.07);
    }
    .sidebar-link:hover .icon {
      background: rgba(79,70,229,.15);
    }
    .sidebar-link.active {
      color: #fff;
      background: linear-gradient(135deg, rgba(79,70,229,.22), rgba(124,58,237,.14));
      border-color: rgba(79,70,229,.35);
      font-weight: 600;
    }
    .sidebar-link.active .icon {
      background: rgba(79,70,229,.25);
    }
    .sidebar-link.active::before {
      content: '';
      position: absolute; left: -12px; top: 50%;
      transform: translateY(-50%);
      width: 3px; height: 22px;
      background: linear-gradient(to bottom, #4f46e5, #7c3aed);
      border-radius: 0 3px 3px 0;
    }
    .sidebar-link.ai-link { color: #a5b4fc; }
    .sidebar-link.ai-link .icon { background: rgba(79,70,229,.12); }
    .sidebar-link.ai-link:hover { background: rgba(79,70,229,.12); border-color: rgba(79,70,229,.25); color: #c7d2fe; }
    .sidebar-link.import-link { color: #34d399; }
    .sidebar-link.import-link .icon { background: rgba(52,211,153,.08); }
    .sidebar-link.import-link:hover { background: rgba(52,211,153,.08); border-color: rgba(52,211,153,.2); color: #6ee7b7; }

    /* User panel at bottom */
    .sidebar-footer {
      margin-top: auto;
      padding: 14px 12px;
      border-top: 1px solid var(--border);
      flex-shrink: 0;
    }
    .user-panel {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px; border-radius: 12px;
      background: rgba(255,255,255,.04);
      border: 1px solid var(--border);
    }
    .user-avatar {
      width: 34px; height: 34px; border-radius: 10px; flex-shrink: 0;
      background: linear-gradient(135deg,rgba(79,70,229,.35),rgba(124,58,237,.25));
      display: flex; align-items: center; justify-content: center;
      font-family: 'Poppins', sans-serif; font-weight: 700;
      font-size: 14px; color: #a5b4fc;
      border: 1px solid rgba(79,70,229,.25);
    }
    .user-info { flex: 1; min-width: 0; }
    .user-name { font-size: 12.5px; font-weight: 600; color: #e2e8f0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .user-role { font-size: 10px; color: var(--muted2); }
    .logout-form { flex-shrink: 0; }
    .logout-btn {
      width: 30px; height: 30px; border-radius: 8px;
      background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.2);
      color: #fca5a5; font-size: 14px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: all .17s;
    }
    .logout-btn:hover { background: rgba(239,68,68,.22); border-color: rgba(239,68,68,.4); }

    /* Mobile toggle button */
    .sidebar-toggle {
      display: none; position: fixed;
      top: 14px; left: 14px; z-index: 200;
      width: 40px; height: 40px; border-radius: 12px;
      background: rgba(8,13,35,.95); border: 1px solid rgba(255,255,255,.1);
      color: #fff; font-size: 18px; cursor: pointer;
      align-items: center; justify-content: center;
      backdrop-filter: blur(12px);
      transition: all .18s;
    }
    .sidebar-toggle:hover { background: rgba(79,70,229,.3); border-color: rgba(79,70,229,.5); }

    /* Mobile overlay */
    .sidebar-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.6); backdrop-filter: blur(4px);
      z-index: 40;
    }
    .sidebar-overlay.show { display: block; }

    /* ════════════ MAIN CONTENT ════════════ */
    .main-wrap {
      margin-left: var(--sidebar-w);
      min-height: 100vh;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    /* Top bar inside main */
    .topbar {
      height: 58px; padding: 0 28px;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 1px solid var(--border);
      background: rgba(6,11,26,.6);
      backdrop-filter: blur(20px);
      position: sticky; top: 0; z-index: 30;
      flex-shrink: 0;
    }
    .topbar-title {
      font-family: 'Poppins', sans-serif;
      font-size: 16px; font-weight: 700; color: #fff;
    }
    .topbar-breadcrumb {
      font-size: 12px; color: var(--muted); margin-top: 1px;
    }
    .topbar-right { display: flex; align-items: center; gap: 10px; }

    .page-content {
      flex: 1;
      padding: 28px 28px 40px;
      max-width: 1160px;
      width: 100%;
    }

    /* ════════════ GLOBAL COMPONENTS ════════════ */

    /* Glass card */
    .g-card {
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 18px;
      backdrop-filter: blur(16px);
      position: relative; overflow: hidden;
      transition: background .2s, border-color .2s, transform .22s, box-shadow .22s;
    }
    .g-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg,transparent,rgba(255,255,255,.09),transparent);
      pointer-events: none;
    }
    .g-card:hover { background: rgba(255,255,255,.055); border-color: rgba(255,255,255,.12); transform: translateY(-2px); box-shadow: 0 14px 44px rgba(0,0,0,.3); }
    .g-card-p { padding: 22px 24px; }

    /* Buttons */
    .btn { display:inline-flex;align-items:center;gap:7px;padding:9px 18px;border-radius:11px;font-size:13px;font-weight:600;text-decoration:none;cursor:pointer;border:none;transition:all .18s;font-family:'Inter',sans-serif;white-space:nowrap; }
    .btn-primary { background:linear-gradient(135deg,#4f46e5,#7c3aed);color:#fff;box-shadow:0 4px 16px rgba(79,70,229,.35); }
    .btn-primary:hover { box-shadow:0 8px 28px rgba(79,70,229,.55);transform:translateY(-1px); }
    .btn-ghost { background:rgba(255,255,255,.05);color:#94a3b8;border:1px solid rgba(255,255,255,.1); }
    .btn-ghost:hover { background:rgba(255,255,255,.1);color:#fff;border-color:rgba(255,255,255,.2); }
    .btn-danger { background:rgba(239,68,68,.1);color:#fca5a5;border:1px solid rgba(239,68,68,.22); }
    .btn-danger:hover { background:rgba(239,68,68,.2);border-color:rgba(239,68,68,.4); }
    .btn-success { background:linear-gradient(135deg,#059669,#10b981);color:#fff;box-shadow:0 4px 14px rgba(16,185,129,.28); }
    .btn-success:hover { box-shadow:0 8px 26px rgba(16,185,129,.45);transform:translateY(-1px); }
    .btn-sm { padding:7px 14px;font-size:12px;border-radius:9px; }

    /* Badges */
    .badge { display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:600; }
    .badge-green  { background:rgba(34,197,94,.1);  color:#86efac;border:1px solid rgba(34,197,94,.2); }
    .badge-amber  { background:rgba(245,158,11,.1); color:#fcd34d;border:1px solid rgba(245,158,11,.2); }
    .badge-red    { background:rgba(239,68,68,.1);  color:#fca5a5;border:1px solid rgba(239,68,68,.2); }
    .badge-blue   { background:rgba(59,130,246,.1); color:#93c5fd;border:1px solid rgba(59,130,246,.2); }
    .badge-violet { background:rgba(139,92,246,.1); color:#c4b5fd;border:1px solid rgba(139,92,246,.2); }
    .badge-cyan   { background:rgba(6,182,212,.1);  color:#67e8f9;border:1px solid rgba(6,182,212,.2); }

    /* Form inputs */
    .g-input,.g-select,.g-textarea { width:100%;padding:10px 13px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:11px;color:#f1f5f9;font-size:13.5px;font-family:'Inter',sans-serif;transition:all .18s;outline:none; }
    .g-input:focus,.g-select:focus,.g-textarea:focus { background:rgba(79,70,229,.08);border-color:rgba(99,102,241,.65);box-shadow:0 0 0 3px rgba(99,102,241,.14); }
    .g-input::placeholder,.g-textarea::placeholder { color:#1e293b; }
    .g-select option { background:#0d1432;color:#f1f5f9; }
    .g-label { display:block;font-size:11px;font-weight:700;color:#334155;text-transform:uppercase;letter-spacing:.7px;margin-bottom:6px; }

    /* Table */
    .g-table { width:100%;border-collapse:collapse; }
    .g-table thead th { padding:11px 16px;font-size:10.5px;font-weight:700;color:#334155;text-transform:uppercase;letter-spacing:.8px;background:rgba(255,255,255,.02);border-bottom:1px solid rgba(255,255,255,.07);text-align:left;white-space:nowrap; }
    .g-table tbody td { padding:13px 16px;border-bottom:1px solid rgba(255,255,255,.04);font-size:13.5px;color:#94a3b8; }
    .g-table tbody tr { transition:background .12s; }
    .g-table tbody tr:hover td { background:rgba(79,70,229,.07);color:#e2e8f0; }
    .g-table tbody tr:last-child td { border-bottom:none; }

    /* Alerts */
    .g-alert { display:flex;align-items:center;gap:12px;padding:13px 17px;border-radius:13px;font-size:13.5px;font-weight:500;margin-bottom:18px;animation:fadeUp .3s ease; }
    .g-alert-success { background:rgba(34,197,94,.08); border:1px solid rgba(34,197,94,.2);  color:#86efac; }
    .g-alert-error   { background:rgba(239,68,68,.08); border:1px solid rgba(239,68,68,.2);  color:#fca5a5; }
    .g-alert-warn    { background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2); color:#fcd34d; }
    .g-alert-info    { background:rgba(59,130,246,.08);border:1px solid rgba(59,130,246,.2); color:#93c5fd; }

    /* Utilities */
    .g-divider  { height:1px;background:rgba(255,255,255,.07);margin:22px 0; }
    .g-prog     { height:5px;background:rgba(255,255,255,.07);border-radius:99px;overflow:hidden; }
    .g-prog-fill{ height:100%;border-radius:99px;transition:width .9s cubic-bezier(.4,0,.2,1); }
    .grad       { background:linear-gradient(90deg,#818cf8,#06b6d4,#34d399);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text; }
    .grad-cool  { background:linear-gradient(90deg,#a78bfa,#818cf8,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text; }
    .page-title { font-family:'Poppins',sans-serif;font-size:23px;font-weight:800;color:#fff;letter-spacing:-.4px; }
    .page-sub   { font-size:13px;color:#334155;margin-top:4px; }
    .g-avatar   { display:flex;align-items:center;justify-content:center;border-radius:12px;font-family:'Poppins',sans-serif;font-weight:700;flex-shrink:0;background:linear-gradient(135deg,rgba(79,70,229,.3),rgba(124,58,237,.18));color:#a5b4fc;border:1px solid rgba(79,70,229,.22); }
    .live-dot   { width:7px;height:7px;border-radius:50%;background:#22c55e;box-shadow:0 0 7px #22c55e;display:inline-block;animation:pulseDot 2s infinite; }

    /* Modals & overlays */
    .g-overlay { position:fixed;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(5px);z-index:100; }
    .g-modal   { background:#0d1432;border:1px solid rgba(255,255,255,.1);border-radius:20px;box-shadow:0 28px 70px rgba(0,0,0,.55);overflow:hidden; }

    /* Animations */
    @keyframes fadeUp   { from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none} }
    @keyframes pulseDot { 0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(.8)} }
    .anim-in  { animation:fadeUp .3s ease both; }
    .anim-in2 { animation:fadeUp .3s .1s ease both; }
    .anim-in3 { animation:fadeUp .3s .2s ease both; }

    /* ════════════ RESPONSIVE ════════════ */
    @media (max-width: 900px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); }
      .main-wrap { margin-left: 0; }
      .sidebar-toggle { display: flex; }
      .page-content { padding: 20px 18px 36px; }
      .topbar { padding: 0 18px 0 64px; }
    }
    @media (max-width: 540px) {
      .page-content { padding: 16px 14px 32px; }
    }
  </style>
</head>
<body>

<!-- Mobile overlay -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- Mobile toggle -->
<button class="sidebar-toggle" id="sidebarToggle" aria-label="Open menu">☰</button>

<!-- ══ SIDEBAR ══ -->
<aside class="sidebar" id="sidebar">
  <!-- Logo -->
  <a href="/" class="sidebar-logo">
    <img src="/logo.png" alt="UMM" onerror="this.style.display='none'">
    <div>
      <div class="sidebar-logo-text">Alumni Tracker</div>
      <div class="sidebar-logo-sub">Universitas Muhammadiyah Malang</div>
    </div>
  </a>

  <!-- Main navigation -->
  <div class="sidebar-section">
    <div class="sidebar-section-label">Menu Utama</div>

    <a href="/" class="sidebar-link <% if(currentPath==='/')          {%>active<%}%>">
      <span class="icon">📊</span>Dashboard
    </a>
    <a href="/data" class="sidebar-link <% if(currentPath==='/data')  {%>active<%}%>">
      <span class="icon">🎓</span>Data Alumni
    </a>
    <a href="/pipeline" class="sidebar-link <% if(currentPath==='/pipeline'){%>active<%}%>">
      <span class="icon">🔍</span>Pipeline
    </a>
  </div>

  <!-- Tools -->
  <div class="sidebar-section">
    <div class="sidebar-section-label">Tools</div>

    <a href="/tracker" class="sidebar-link ai-link <% if(currentPath==='/tracker'){%>active<%}%>">
      <span class="icon">⚡</span>AI Tracker
    </a>
    <% if (user && user.role === 'admin') { %>
    <a href="/import" class="sidebar-link import-link <% if(currentPath==='/import'){%>active<%}%>">
      <span class="icon">📥</span>Import Data
    </a>
    <% } %>
    <a href="/export" class="sidebar-link">
      <span class="icon">⬇️</span>Export Excel
    </a>
    <a href="/add" class="sidebar-link">
      <span class="icon">➕</span>Tambah Alumni
    </a>
  </div>

  <!-- User panel at bottom -->
  <% if (user) { %>
  <div class="sidebar-footer">
    <div class="user-panel">
      <div class="user-avatar"><%= user.namaLengkap.charAt(0).toUpperCase() %></div>
      <div class="user-info">
        <div class="user-name"><%= user.namaLengkap %></div>
        <div class="user-role" style="color:<%= user.role==='admin'?'#818cf8':'#475569' %>"><%= user.role==='admin'?'👑 Admin':'👁 Viewer' %></div>
      </div>
      <div class="logout-form">
        <form action="/logout" method="POST">
          <button type="submit" class="logout-btn" title="Keluar">⎋</button>
        </form>
      </div>
    </div>
  </div>
  <% } %>
</aside>

<!-- ══ MAIN CONTENT WRAPPER ══ -->
<div class="main-wrap">

  <!-- Top bar -->
  <div class="topbar">
    <div>
      <div class="topbar-title">
        <% if (currentPath==='/') { %>📊 Dashboard
        <% } else if (currentPath==='/data') { %>🎓 Data Alumni
        <% } else if (currentPath==='/pipeline') { %>🔍 Pipeline Verifikasi
        <% } else if (currentPath==='/tracker') { %>⚡ AI Tracker
        <% } else if (currentPath==='/import') { %>📥 Import Data
        <% } else { %><%= title %>
        <% } %>
      </div>
      <div class="topbar-breadcrumb">Alumni Tracker UMM &rsaquo; <%= title %></div>
    </div>
    <div class="topbar-right">
      <span style="display:flex;align-items:center;gap:6px;font-size:12px;color:#22c55e;font-weight:600">
        <span class="live-dot"></span>Live
      </span>
      <% if (user && user.role === 'admin') { %>
      <a href="/add" class="btn btn-primary btn-sm">+ Tambah</a>
      <% } %>
    </div>
  </div>

  <!-- Page content -->
  <div class="page-content">

