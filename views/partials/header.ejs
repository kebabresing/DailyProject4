<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Alumni Tracker UMM</title>
  <meta name="description" content="Alumni Tracker UMM — Platform pelacakan dan manajemen alumni Universitas Muhammadiyah Malang.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,600;0,700;0,800;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    /* ══════════════════════════════════════════
       ALUMNI TRACKER — GLOBAL DESIGN SYSTEM
       Dark Glassmorphism • SaaS Premium Look
    ══════════════════════════════════════════ */
    :root {
      --bg:     #060b1a;
      --glass:  rgba(255,255,255,0.05);
      --border: rgba(255,255,255,0.09);
      --indigo: #4f46e5;
      --violet: #7c3aed;
      --cyan:   #06b6d4;
      --green:  #22c55e;
      --text:   #f1f5f9;
      --muted:  #64748b;
      --nav-h:  62px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      min-height: 100vh;
      background:
        radial-gradient(ellipse 110% 65% at 10% -5%, rgba(79,70,229,.22) 0%, transparent 55%),
        radial-gradient(ellipse 80%  55% at 90% 105%, rgba(6,182,212,.14) 0%, transparent 50%),
        radial-gradient(ellipse 50%  40% at 50%  50%, rgba(124,58,237,.06) 0%, transparent 60%),
        linear-gradient(165deg, #060b1a 0%, #0c1230 50%, #080e24 100%);
      background-attachment: fixed;
      color: var(--text);
      -webkit-font-smoothing: antialiased;
    }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,.14); border-radius: 99px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,.24); }

    /* ── Typography ── */
    h1, h2, h3, .f-poppins { font-family: 'Poppins', sans-serif; }

    /* ════════════════════════════════════
       NAVIGATION
    ════════════════════════════════════ */
    nav.glass-nav {
      background: rgba(6,11,26,.80);
      backdrop-filter: blur(28px);
      -webkit-backdrop-filter: blur(28px);
      border-bottom: 1px solid rgba(255,255,255,.07);
      position: sticky; top: 0; z-index: 100;
      box-shadow: 0 1px 0 rgba(255,255,255,.04), 0 8px 32px rgba(0,0,0,.5);
    }
    .nav-inner {
      max-width: 1300px; margin: 0 auto; padding: 0 28px;
      height: var(--nav-h);
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .nav-logo img {
      height: 38px; width: auto; object-fit: contain;
      filter: drop-shadow(0 0 10px rgba(79,70,229,.5));
      transition: filter .2s;
    }
    .nav-logo:hover img { filter: drop-shadow(0 0 16px rgba(79,70,229,.75)); }
    .nav-logo-text { font-family: 'Poppins', sans-serif; font-size: 15px; font-weight: 700; color: #fff; line-height: 1.25; }
    .nav-logo-sub  { font-size: 10px; color: #334155; font-weight: 500; letter-spacing: .3px; }

    .nav-links { display: flex; align-items: center; gap: 2px; }
    .nav-link {
      display: flex; align-items: center; gap: 6px;
      padding: 7px 13px; border-radius: 10px;
      font-size: 13px; font-weight: 600; color: #475569;
      text-decoration: none; transition: all .18s; white-space: nowrap;
      border: 1px solid transparent;
    }
    .nav-link:hover { color: #e2e8f0; background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.09); }
    .nav-link.active {
      color: #fff; background: rgba(79,70,229,.22);
      border-color: rgba(79,70,229,.45);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 2px 8px rgba(79,70,229,.2);
    }
    .nav-link.tracker-link { color: #a5b4fc; background: rgba(79,70,229,.1); border-color: rgba(79,70,229,.22); }
    .nav-link.tracker-link:hover { background: rgba(79,70,229,.2); border-color: rgba(79,70,229,.45); box-shadow: 0 0 20px rgba(79,70,229,.15); }
    .nav-link.import-link { color: #34d399; }
    .nav-link.import-link:hover { background: rgba(52,211,153,.1); border-color: rgba(52,211,153,.25); color: #6ee7b7; }

    .user-chip {
      display: flex; align-items: center; gap: 10px;
      padding: 4px 4px 4px 14px;
      background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08);
      border-radius: 99px; margin-left: 14px;
    }
    .user-chip .uname { font-size: 12.5px; font-weight: 600; color: #e2e8f0; }
    .user-chip .ulab  { font-size: 10px; color: #334155; }
    .logout-btn {
      padding: 6px 14px;
      background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.2);
      border-radius: 99px; color: #fca5a5;
      font-size: 12px; font-weight: 600; cursor: pointer;
      transition: all .18s; font-family: 'Inter', sans-serif;
    }
    .logout-btn:hover { background: rgba(239,68,68,.2); border-color: rgba(239,68,68,.4); }

    /* Mobile nav */
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 8px; border: none; background: none; }
    .hamburger span { width: 22px; height: 2px; background: #94a3b8; border-radius: 99px; transition: .2s; }
    .hamburger:hover span { background: #fff; }
    .mobile-drawer {
      display: none; flex-direction: column; gap: 6px;
      padding: 14px 20px; border-top: 1px solid rgba(255,255,255,.07);
      background: rgba(4,8,22,.95); backdrop-filter: blur(24px);
    }
    .mobile-drawer.open { display: flex; }
    .mobile-drawer .nav-link { width: 100%; }
    @media (max-width: 860px) {
      .nav-links, .user-chip { display: none; }
      .hamburger { display: flex; }
    }

    /* ════════════════════════════════════
       GLOBAL COMPONENT SYSTEM
    ════════════════════════════════════ */

    /* Glass card */
    .g-card {
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 20px;
      backdrop-filter: blur(20px);
      position: relative; overflow: hidden;
      transition: background .2s, border-color .2s, transform .25s, box-shadow .25s;
    }
    .g-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,.1), transparent);
      pointer-events: none;
    }
    .g-card:hover {
      background: rgba(255,255,255,.065);
      border-color: rgba(255,255,255,.13);
      transform: translateY(-2px);
      box-shadow: 0 16px 50px rgba(0,0,0,.35);
    }
    .g-card-p { padding: 24px 26px; }
    .g-card-flat { background: rgba(255,255,255,.025); border: 1px solid rgba(255,255,255,.06); border-radius: 14px; }

    /* Buttons */
    .btn {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 10px 20px; border-radius: 12px;
      font-size: 13px; font-weight: 600;
      text-decoration: none; cursor: pointer; border: none;
      transition: all .2s; font-family: 'Inter', sans-serif;
      white-space: nowrap; letter-spacing: .1px;
    }
    .btn-primary {
      background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
      color: #fff; box-shadow: 0 4px 18px rgba(79,70,229,.38);
    }
    .btn-primary:hover { box-shadow: 0 8px 30px rgba(79,70,229,.58); transform: translateY(-1px); }
    .btn-primary:active { transform: translateY(0); box-shadow: 0 4px 12px rgba(79,70,229,.35); }
    .btn-ghost {
      background: rgba(255,255,255,.05); color: #94a3b8;
      border: 1px solid rgba(255,255,255,.1);
    }
    .btn-ghost:hover { background: rgba(255,255,255,.1); color: #fff; border-color: rgba(255,255,255,.2); }
    .btn-danger {
      background: rgba(239,68,68,.1); color: #fca5a5;
      border: 1px solid rgba(239,68,68,.22);
    }
    .btn-danger:hover { background: rgba(239,68,68,.2); border-color: rgba(239,68,68,.4); }
    .btn-success {
      background: linear-gradient(135deg, #059669, #10b981);
      color: #fff; box-shadow: 0 4px 16px rgba(16,185,129,.28);
    }
    .btn-success:hover { box-shadow: 0 8px 28px rgba(16,185,129,.45); transform: translateY(-1px); }
    .btn-sm { padding: 7px 14px; font-size: 12px; border-radius: 9px; gap: 5px; }
    .btn-xs { padding: 5px 10px; font-size: 11.5px; border-radius: 8px; gap: 4px; }

    /* Badges */
    .badge {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 3px 10px; border-radius: 99px;
      font-size: 11.5px; font-weight: 600;
    }
    .badge-green  { background: rgba(34,197,94,.1);  color: #86efac; border: 1px solid rgba(34,197,94,.2); }
    .badge-amber  { background: rgba(245,158,11,.1); color: #fcd34d; border: 1px solid rgba(245,158,11,.2); }
    .badge-red    { background: rgba(239,68,68,.1);  color: #fca5a5; border: 1px solid rgba(239,68,68,.2); }
    .badge-blue   { background: rgba(59,130,246,.1); color: #93c5fd; border: 1px solid rgba(59,130,246,.2); }
    .badge-violet { background: rgba(139,92,246,.1); color: #c4b5fd; border: 1px solid rgba(139,92,246,.2); }
    .badge-cyan   { background: rgba(6,182,212,.1);  color: #67e8f9; border: 1px solid rgba(6,182,212,.2); }
    .badge-dot::before { content: ''; display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: currentColor; margin-right: 2px; opacity: .8; }

    /* Form inputs */
    .g-input, .g-select, .g-textarea {
      width: 100%; padding: 11px 14px;
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 12px; color: #f1f5f9;
      font-size: 14px; font-family: 'Inter', sans-serif;
      transition: all .2s; outline: none;
      -webkit-appearance: none;
    }
    .g-input:focus, .g-select:focus, .g-textarea:focus {
      background: rgba(79,70,229,.08);
      border-color: rgba(99,102,241,.7);
      box-shadow: 0 0 0 3px rgba(99,102,241,.15);
    }
    .g-input::placeholder, .g-textarea::placeholder { color: #1e293b; }
    .g-select option { background: #0d1432; color: #f1f5f9; }
    .g-label {
      display: block; font-size: 11.5px; font-weight: 700;
      color: #475569; text-transform: uppercase; letter-spacing: .6px;
      margin-bottom: 7px;
    }

    /* Table */
    .g-table { width: 100%; border-collapse: collapse; }
    .g-table thead th {
      padding: 12px 18px; font-size: 10.5px; font-weight: 700;
      color: #334155; text-transform: uppercase; letter-spacing: .8px;
      background: rgba(255,255,255,.02); border-bottom: 1px solid rgba(255,255,255,.07);
      text-align: left; white-space: nowrap;
    }
    .g-table tbody td { padding: 14px 18px; border-bottom: 1px solid rgba(255,255,255,.04); font-size: 13.5px; color: #94a3b8; }
    .g-table tbody tr { transition: background .12s; }
    .g-table tbody tr:hover td { background: rgba(79,70,229,.07); color: #e2e8f0; }
    .g-table tbody tr:last-child td { border-bottom: none; }

    /* Alert banners */
    .g-alert {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 18px; border-radius: 14px;
      font-size: 13.5px; font-weight: 500; margin-bottom: 20px;
      animation: fadeInSlide .3s ease;
    }
    .g-alert-success { background: rgba(34,197,94,.08);  border: 1px solid rgba(34,197,94,.2);  color: #86efac; }
    .g-alert-error   { background: rgba(239,68,68,.08);  border: 1px solid rgba(239,68,68,.2);  color: #fca5a5; }
    .g-alert-warn    { background: rgba(245,158,11,.08); border: 1px solid rgba(245,158,11,.2); color: #fcd34d; }
    .g-alert-info    { background: rgba(59,130,246,.08); border: 1px solid rgba(59,130,246,.2); color: #93c5fd; }

    /* Progress bar */
    .g-prog { height: 6px; background: rgba(255,255,255,.08); border-radius: 99px; overflow: hidden; }
    .g-prog-fill { height: 100%; border-radius: 99px; transition: width .9s cubic-bezier(.4,0,.2,1); }

    /* Utilities */
    .g-divider { height: 1px; background: rgba(255,255,255,.07); margin: 24px 0; }
    .grad      { background: linear-gradient(90deg,#818cf8,#06b6d4,#34d399); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .grad-cool { background: linear-gradient(90deg,#a78bfa,#818cf8,#06b6d4); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .g-avatar  {
      display: flex; align-items: center; justify-content: center;
      border-radius: 14px; font-family: 'Poppins', sans-serif; font-weight: 700;
      flex-shrink: 0;
      background: linear-gradient(135deg, rgba(79,70,229,.3), rgba(124,58,237,.18));
      color: #a5b4fc; border: 1px solid rgba(79,70,229,.22);
    }
    .page-title { font-family: 'Poppins', sans-serif; font-size: 26px; font-weight: 800; color: #fff; letter-spacing: -.5px; }
    .page-sub   { font-size: 13.5px; color: #334155; margin-top: 5px; }
    .live-dot   { width: 8px; height: 8px; border-radius: 50%; background: #22c55e; box-shadow: 0 0 8px #22c55e; display: inline-block; animation: pulseDot 2s infinite; }

    /* Overlay for modals */
    .g-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.6); backdrop-filter: blur(4px); z-index: 100; }
    .g-modal   { background: #0d1432; border: 1px solid rgba(255,255,255,.1); border-radius: 22px; box-shadow: 0 32px 80px rgba(0,0,0,.6); overflow: hidden; }

    /* Animations */
    @keyframes fadeInSlide { from { opacity:0; transform:translateY(-6px); } to { opacity:1; transform:none; } }
    @keyframes fadeInUp    { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:none; } }
    @keyframes pulseDot    { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.85)} }
    @keyframes shimmer     { 0%{background-position:-200% 0} 100%{background-position:200% 0} }
    .anim-in  { animation: fadeInUp .35s ease both; }
    .anim-in2 { animation: fadeInUp .35s .1s ease both; }
    .anim-in3 { animation: fadeInUp .35s .2s ease both; }
  </style>
</head>
<body>

<nav class="glass-nav" aria-label="Main navigation">
  <div class="nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Alumni Tracker UMM Home">
      <img src="/logo.png" alt="Logo UMM" onerror="this.style.display='none'">
      <div>
        <div class="nav-logo-text">Alumni Tracker</div>
        <div class="nav-logo-sub">Universitas Muhammadiyah Malang</div>
      </div>
    </a>

    <!-- Desktop nav -->
    <div class="nav-links">
      <a href="/" class="nav-link <% if(currentPath==='/')          {%>active<%}%>">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        Dashboard
      </a>
      <a href="/data" class="nav-link <% if(currentPath==='/data')  {%>active<%}%>">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
        Data Alumni
      </a>
      <a href="/pipeline" class="nav-link <% if(currentPath==='/pipeline'){%>active<%}%>">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        Pipeline
      </a>
      <a href="/tracker" class="nav-link tracker-link <% if(currentPath==='/tracker'){%>active<%}%>">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        AI Tracker
      </a>
      <% if (user && user.role === 'admin') { %>
      <a href="/import" class="nav-link import-link <% if(currentPath==='/import'){%>active<%}%>">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
        Import
      </a>
      <% } %>

      <% if (user) { %>
      <div class="user-chip">
        <div>
          <div class="uname"><%= user.namaLengkap %></div>
          <div class="ulab" style="<%= user.role === 'admin' ? 'color:#818cf8' : 'color:#475569' %>"><%= user.role === 'admin' ? '👑 Admin' : '👁 Viewer' %></div>
        </div>
        <form action="/logout" method="POST" style="margin:0">
          <button type="submit" class="logout-btn">Keluar</button>
        </form>
      </div>
      <% } %>
    </div>

    <!-- Hamburger -->
    <button class="hamburger" id="hamburgerBtn" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-drawer" id="mobileDrawer">
    <a href="/"         class="nav-link">📊 Dashboard</a>
    <a href="/data"     class="nav-link">📋 Data Alumni</a>
    <a href="/pipeline" class="nav-link">🔍 Pipeline</a>
    <a href="/tracker"  class="nav-link tracker-link">⚡ AI Tracker</a>
    <% if (user && user.role === 'admin') { %>
    <a href="/import"   class="nav-link import-link">📥 Import</a>
    <% } %>
    <% if (user) { %>
    <form action="/logout" method="POST" style="margin-top:6px">
      <button type="submit" class="logout-btn" style="width:100%;padding:10px">🚪 Keluar</button>
    </form>
    <% } %>
  </div>
</nav>

<main style="max-width:1300px;margin:0 auto;padding:32px 28px;min-height:calc(100vh - var(--nav-h) - 68px)">

