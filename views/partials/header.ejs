<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3, .font-outfit { font-family: 'Outfit', sans-serif; }
        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body class="text-slate-700 bg-gradient-to-br from-slate-50 via-white to-indigo-50/50 flex flex-col min-h-screen selection:bg-indigo-500/30">
    <nav class="bg-white/60 backdrop-blur-2xl border-b border-slate-200/80 shadow-[0_2px_16px_rgba(0,0,0,0.07)] w-full sticky top-0 z-50 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <!-- Logo -->
                <div class="flex items-center group cursor-pointer">
                    <a href="/">
                        <img src="/logo.png" alt="Alumni Tracker Logo" class="h-16 w-auto group-hover:scale-105 transition-transform duration-300">
                    </a>
                </div>
                <!-- Navigation Links -->
                <div class="hidden sm:flex items-center space-x-1">
                    <a href="/" class="text-slate-600 hover:text-indigo-600 hover:bg-indigo-50/50 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-300">Laporan Statistik</a>
                    <a href="/data" class="text-slate-600 hover:text-indigo-600 hover:bg-indigo-50/50 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-300">Data Master</a>
                    <a href="/pipeline" class="text-slate-600 hover:text-indigo-600 hover:bg-indigo-50/50 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-300">🔍 Pipeline</a>
                    <a href="/tracker" class="text-violet-600 hover:text-violet-800 bg-violet-50 hover:bg-violet-100 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-300 ring-1 ring-inset ring-violet-200">🤖 Intelligent Tracker</a>
                    <% if (user) { %>
                    <div class="flex items-center gap-3 ml-4 pl-4 border-l border-slate-200">
                        <div class="text-right">
                            <div class="text-xs text-slate-400 font-medium">Login sebagai</div>
                            <div class="text-sm font-bold text-slate-700"><%= user.namaLengkap %></div>
                        </div>
                        <form action="/logout" method="POST">
                            <button type="submit" class="bg-red-50 hover:bg-red-100 text-red-600 text-xs font-bold px-3 py-2 rounded-lg transition-all duration-200 border border-red-100 hover:border-red-200">
                                🚪 Keluar
                            </button>
                        </form>
                    </div>
                    <% } %>
                </div>
                <!-- Mobile Navigation -->
                <div class="flex sm:hidden items-center space-x-2">
                     <a href="/" class="text-indigo-600 text-sm font-semibold bg-indigo-50 px-3 py-1.5 rounded-lg">Laporan</a>
                     <a href="/data" class="text-indigo-600 text-sm font-semibold bg-indigo-50 px-3 py-1.5 rounded-lg">Data</a>
                     <a href="/tracker" class="text-violet-600 text-sm font-semibold bg-violet-50 px-3 py-1.5 rounded-lg">🤖 Tracker</a>
                     <% if (user) { %>
                     <form action="/logout" method="POST">
                         <button type="submit" class="text-red-500 text-sm font-semibold bg-red-50 px-3 py-1.5 rounded-lg border border-red-100">Keluar</button>
                     </form>
                     <% } %>
                </div>
            </div>
        </div>
    </nav>
    <main class="flex-grow w-full max-w-7xl mx-auto">
