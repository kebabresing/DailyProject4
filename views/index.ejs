<%- include('partials/header') %>


<div class="px-4 py-8 sm:px-0">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-4">
        <div>
            <h1 class="text-3xl sm:text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-slate-900 to-slate-600 tracking-tight font-outfit">Data Master Alumni</h1>
            <p class="text-sm text-slate-500 mt-1 font-medium">
                Menampilkan alumni teridentifikasi dari sumber publik
                <% const activeFilterCount = (filters.tahunLulus ? 1 : 0) + (filters.jenisPekerjaan ? 1 : 0) + (search ? 1 : 0); %>
                <% if (activeFilterCount > 0) { %>
                <span class="inline-flex items-center ml-2 px-2 py-0.5 rounded-full text-xs font-bold bg-indigo-100 text-indigo-700">
                    <%= activeFilterCount %> filter aktif
                </span>
                <% } %>
            </p>
        </div>
        <div class="flex flex-wrap items-center gap-2">
            <a href="/add" class="inline-flex items-center px-4 py-2.5 text-sm font-semibold rounded-xl text-white bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-700 hover:to-violet-700 shadow-lg shadow-indigo-500/30 transition-all duration-200 hover:-translate-y-0.5">
                <svg class="-ml-1 mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                Tambah
            </a>
            <a href="/export" class="inline-flex items-center px-4 py-2.5 text-sm font-semibold rounded-xl text-emerald-700 bg-emerald-50 hover:bg-emerald-100 border border-emerald-200 shadow-sm transition-all duration-200 hover:-translate-y-0.5">
                <svg class="-ml-1 mr-2 h-4 w-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                Export Excel
            </a>
        </div>
    </div>

    <!-- Search & Filter Panel -->
    <div class="bg-white/80 backdrop-blur-xl border border-slate-200/70 rounded-2xl shadow-sm p-4 mb-6">
        <form action="/data" method="GET" id="searchForm">
            <div class="flex flex-col md:flex-row gap-3">
                <!-- Search input dengan debounce -->
                <div class="flex-1 relative group">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                        <svg id="search-icon" class="h-4 w-4 text-slate-400 group-focus-within:text-indigo-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                        <!-- Spinner saat loading -->
                        <svg id="search-spinner" class="h-4 w-4 text-indigo-500 animate-spin hidden" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                        </svg>
                    </div>
                    <input type="text" name="search" id="searchInput"
                        placeholder="Cari nama, NIM, prodi... (debounce 400ms)"
                        value="<%= search %>"
                        autocomplete="off"
                        class="block w-full pl-10 pr-10 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 focus:bg-white transition-all">
                    <!-- Clear search button -->
                    <button type="button" id="clearSearch"
                        class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-slate-600 transition-colors <%= search ? '' : 'hidden' %>"
                        title="Hapus pencarian">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </div>

                <!-- Filter: Tahun Lulus -->
                <div class="relative">
                    <select name="tahun" id="tahunFilter"
                        class="appearance-none pl-4 pr-9 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:bg-white transition-all cursor-pointer min-w-[140px] <%= filters.tahunLulus ? 'border-indigo-400 bg-indigo-50 text-indigo-700' : '' %>">
                        <option value="">📅 Semua Tahun</option>
                        <% TAHUN_OPTIONS.forEach(t => { %>
                        <option value="<%= t %>" <%= filters.tahunLulus == t ? 'selected' : '' %>><%= t %></option>
                        <% }); %>
                    </select>
                    <div class="pointer-events-none absolute inset-y-0 right-2.5 flex items-center">
                        <svg class="h-3.5 w-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </div>
                </div>

                <!-- Filter: Jenis Pekerjaan -->
                <div class="relative">
                    <select name="jenis" id="jenisFilter"
                        class="appearance-none pl-4 pr-9 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:bg-white transition-all cursor-pointer min-w-[180px] <%= filters.jenisPekerjaan ? 'border-indigo-400 bg-indigo-50 text-indigo-700' : '' %>">
                        <option value="">💼 Semua Pekerjaan</option>
                        <% JENIS_OPTIONS.forEach(j => { %>
                        <option value="<%= j %>" <%= filters.jenisPekerjaan === j ? 'selected' : '' %>><%= j %></option>
                        <% }); %>
                    </select>
                    <div class="pointer-events-none absolute inset-y-0 right-2.5 flex items-center">
                        <svg class="h-3.5 w-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </div>
                </div>

                <!-- Reset filter button (hanya tampil jika ada filter aktif) -->
                <% if (activeFilterCount > 0) { %>
                <a href="/data" class="inline-flex items-center gap-1.5 px-4 py-2.5 text-sm font-semibold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-xl transition-colors whitespace-nowrap">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    Reset
                </a>
                <% } %>
            </div>

            <!-- Active filter badges -->
            <% if (activeFilterCount > 0) { %>
            <div class="flex flex-wrap gap-2 mt-3">
                <% if (search) { %>
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-indigo-100 text-indigo-700 border border-indigo-200">
                    🔍 "<%= search %>"
                </span>
                <% } %>
                <% if (filters.tahunLulus) { %>
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-sky-100 text-sky-700 border border-sky-200">
                    📅 Lulus <%= filters.tahunLulus %>
                </span>
                <% } %>
                <% if (filters.jenisPekerjaan) { %>
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-violet-100 text-violet-700 border border-violet-200">
                    💼 <%= filters.jenisPekerjaan %>
                </span>
                <% } %>
                <span class="text-xs text-slate-400 self-center">
                    — Menampilkan <%= total.toLocaleString('id-ID') %> hasil
                </span>
            </div>
            <% } %>
        </form>
    </div>

    <!-- Analytics Dashboard Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-white/80 backdrop-blur border border-slate-200/60 rounded-2xl p-5 shadow-sm transform hover:-translate-y-1 transition-all duration-300 text-center sm:text-left">
            <div class="text-xs text-slate-500 font-bold uppercase tracking-wider">Total Database</div>
            <div class="text-3xl font-black text-slate-800 mt-2 font-outfit"><%= stats.total.toLocaleString('id-ID') %><span class="text-sm font-semibold text-slate-400 ml-1">Data</span></div>
        </div>
        <div class="bg-indigo-50 border border-indigo-100 rounded-2xl p-5 shadow-sm transform hover:-translate-y-1 transition-all duration-300 text-center sm:text-left">
            <div class="text-xs text-indigo-500 font-bold uppercase tracking-wider">Profil Terpublikasi</div>
            <div class="text-3xl font-black text-indigo-700 mt-2 font-outfit"><%= stats.teridentifikasi.toLocaleString('id-ID') %></div>
        </div>
        <div class="bg-sky-50 border border-sky-100 rounded-2xl p-5 shadow-sm transform hover:-translate-y-1 transition-all duration-300 text-center sm:text-left">
            <div class="text-xs text-sky-600 font-bold uppercase tracking-wider">Bekerja (PNS/Swasta)</div>
            <div class="text-3xl font-black text-sky-800 mt-2 font-outfit"><%= stats.bekerja.toLocaleString('id-ID') %></div>
        </div>
        <div class="bg-amber-50 border border-amber-100 rounded-2xl p-5 shadow-sm transform hover:-translate-y-1 transition-all duration-300 text-center sm:text-left">
            <div class="text-xs text-amber-600 font-bold uppercase tracking-wider">Wirausaha / Freelance</div>
            <div class="text-3xl font-black text-amber-800 mt-2 font-outfit"><%= stats.wirausaha.toLocaleString('id-ID') %></div>
        </div>
    </div>

    <div class="bg-white/60 backdrop-blur-xl border border-white/60 shadow-2xl shadow-slate-200/50 sm:rounded-2xl overflow-hidden ring-1 ring-slate-200/50">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200/60">
                <thead class="bg-slate-50/50">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider font-outfit">Nama &amp; Prodi</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider font-outfit">Fakultas</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider font-outfit">Lulus / Kampus</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider font-outfit">Status Pelacakan</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-500 uppercase tracking-wider font-outfit text-right">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200/60 bg-transparent">
                    <% if(alumniList && alumniList.length > 0) { %>
                        <% alumniList.forEach(alumni => { %>
                            <tr data-id="<%= alumni.id %>" class="hover:bg-indigo-50/40 transition-colors duration-150 group cursor-pointer alumni-row">
                                <td class="px-6 py-5 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-10 w-10 flex items-center justify-center rounded-full bg-gradient-to-br from-indigo-100 to-violet-100 text-indigo-700 font-bold text-lg font-outfit border border-indigo-200 shadow-sm">
                                            <%= alumni.namaLengkap.charAt(0).toUpperCase() %>
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-bold text-slate-900 font-outfit"><%= alumni.namaLengkap %></div>
                                            <div class="text-xs text-slate-500 font-medium"><%= alumni.nim ? alumni.nim + ' • ' : '' %><%= alumni.prodi %></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-5 whitespace-nowrap">
                                    <div class="text-xs font-semibold text-slate-700"><%= alumni.fakultas || '-' %></div>
                                </td>
                                <td class="px-6 py-5 whitespace-nowrap">
                                    <div class="text-sm font-semibold text-slate-800"><%= alumni.tahunLulus %></div>
                                    <div class="text-xs text-slate-500"><%= alumni.kampus %></div>
                                </td>
                                <td class="px-6 py-5 whitespace-nowrap">
                                    <span class="px-3 py-1 inline-flex text-xs leading-5 font-bold rounded-full border shadow-sm
                                        <%= alumni.confidenceScore >= 70 ? 'bg-emerald-50 text-emerald-700 border-emerald-200 ring-1 ring-inset ring-emerald-600/10' : (alumni.confidenceScore >= 40 ? 'bg-amber-50 text-amber-700 border-amber-200 ring-1 ring-inset ring-amber-600/10' : 'bg-rose-50 text-rose-700 border-rose-200 ring-1 ring-inset ring-rose-600/10') %>">
                                        <span class="<%= alumni.confidenceScore >= 70 ? 'bg-emerald-500' : (alumni.confidenceScore >= 40 ? 'bg-amber-500' : 'bg-rose-500') %> w-1.5 h-1.5 rounded-full mr-2 my-auto animate-pulse"></span>
                                        <%= alumni.status %> (<%= alumni.confidenceScore %>%)
                                    </span>
                                    <div class="text-xs font-medium text-slate-500 mt-2 max-w-xs truncate" title="<%= alumni.jejak %>">
                                        📰 <%= alumni.jejak %>
                                    </div>
                                </td>
                                <td class="px-6 py-5 whitespace-nowrap text-sm font-medium text-right" onclick="event.stopPropagation()">
                                    <a href="/edit/<%= alumni.id %>" class="text-indigo-600 hover:text-indigo-900 mr-4 font-semibold hover:underline">Edit</a>
                                    <button onclick="openDeleteModal('<%= alumni.id %>', '<%= alumni.namaLengkap %>')" class="text-rose-600 hover:text-rose-900 font-semibold hover:underline bg-rose-50 px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200 ring-1 ring-rose-100">Hapus</button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="px-6 py-12 text-center text-slate-500">
                                <div class="flex flex-col items-center">
                                    <svg class="h-12 w-12 text-slate-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 9.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    <p class="text-lg font-bold text-slate-900 font-outfit">
                                        <%= search ? 'Tidak ada kecocokan' : 'Belum ada data' %>
                                    </p>
                                    <p class="text-sm">
                                        <%= search ? `Hasil untuk "${search}" tidak ditemukan.` : 'Mulai dengan menambahkan alumni baru atau simulasi bot.' %>
                                    </p>
                                    <% if(search) { %>
                                        <a href="/data" class="mt-4 text-indigo-600 font-bold hover:underline">Hapus Pencarian</a>
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Alumni data map untuk modal detail -->
        <script>
        const alumniDataMap = {};
        <% alumniList.forEach(function(a) { %>
        alumniDataMap[<%= a.id %>] = <%- JSON.stringify(a) %>;
        <% }); %>
        document.querySelector('tbody').addEventListener('click', function(e) {
            const row = e.target.closest('tr.alumni-row');
            if (!row) return;
            if (e.target.closest('td:last-child')) return;
            const id = parseInt(row.dataset.id);
            if (alumniDataMap[id]) openDetailModal(alumniDataMap[id]);
        });
        </script>

        <!-- Info & Pagination -->

        <div class="px-6 py-4 border-t border-slate-200/60 bg-slate-50/30 flex flex-col sm:flex-row items-center justify-between gap-3">
            <div class="text-sm text-slate-500">
                Menampilkan <span class="font-bold text-slate-700"><%= alumniList.length %></span>
                dari <span class="font-bold text-slate-700"><%= total.toLocaleString('id-ID') %></span> alumni
                <% if(search) { %> · "<span class="text-indigo-600 font-semibold"><%= search %></span>"<% } %>
            </div>
            <% if(totalPages > 1) { %>
            <div class="flex items-center gap-1 flex-wrap">
                <% if(page > 1) { %>
                <a href="/data?page=<%= page-1 %>&search=<%= encodeURIComponent(search) %>" class="px-3 py-1.5 text-sm font-semibold text-slate-600 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-all">← Prev</a>
                <% } %>
                <% const startP = Math.max(1, page-2); const endP = Math.min(totalPages, page+2); %>
                <% for(let p = startP; p <= endP; p++) { %>
                <a href="/data?page=<%= p %>&search=<%= encodeURIComponent(search) %>" class="px-3 py-1.5 text-sm font-semibold rounded-lg transition-all <%= p === page ? 'bg-indigo-600 text-white' : 'text-slate-600 bg-white border border-slate-200 hover:bg-slate-50' %>"><%= p %></a>
                <% } %>
                <% if(page < totalPages) { %>
                <a href="/data?page=<%= page+1 %>&search=<%= encodeURIComponent(search) %>" class="px-3 py-1.5 text-sm font-semibold text-slate-600 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-all">Next →</a>
                <% } %>
                <span class="text-xs text-slate-400 ml-1">Hal. <%= page %>/<%= totalPages.toLocaleString('id-ID') %></span>
            </div>
            <% } %>
        </div>
    </div>
</div>


<!-- Toast Notification -->
<div id="toast-success" class="fixed top-5 right-5 flex items-center w-full max-w-xs p-4 mb-4 text-slate-600 bg-white/80 backdrop-blur-xl border border-slate-200/60 rounded-2xl shadow-xl shadow-slate-200/50 transition-all duration-500 opacity-0 hidden" role="alert" style="z-index: 150;">
    <div id="toast-icon-bg" class="inline-flex items-center justify-center flex-shrink-0 w-10 h-10 text-emerald-600 bg-emerald-100/80 rounded-xl border border-emerald-200 shadow-sm">
        <svg id="toast-icon" class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 8.207-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 0 1 1.414-1.414L9 10.586l3.293-3.293a1 1 0 0 1 1.414 1.414Z"/>
        </svg>
        <span class="sr-only">Icon</span>
    </div>
    <div class="ms-4 text-sm font-normal">
        <span id="toast-title" class="font-bold text-slate-900 font-outfit text-base">Pelacakan Berhasil!</span>
        <div id="toast-message" class="mt-0.5 text-slate-500 font-medium">Data alumni baru ditambahkan.</div>
    </div>
    <button type="button" class="ms-auto -mx-1.5 -my-1.5 bg-transparent text-slate-400 hover:text-slate-900 rounded-lg focus:ring-2 focus:ring-slate-300 p-1.5 hover:bg-slate-100 inline-flex items-center justify-center h-8 w-8 transition-colors" onclick="document.getElementById('toast-success').classList.add('hidden')" aria-label="Close">
        <span class="sr-only">Close</span>
        <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
        </svg>
    </button>
</div>

<!-- Detail Modal -->
<div id="detailModal" class="hidden fixed inset-0 z-[110] flex items-center justify-center p-4" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm" onclick="closeDetailModal()"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden z-10 animate-in">
        <!-- Header -->
        <div class="bg-gradient-to-br from-indigo-600 to-violet-600 px-6 py-5">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <div class="h-14 w-14 rounded-2xl bg-white/20 flex items-center justify-center text-white text-2xl font-bold font-outfit" id="d-avatar"></div>
                    <div>
                        <div class="text-white font-bold text-lg font-outfit" id="d-nama"></div>
                        <div class="text-indigo-200 text-sm" id="d-prodi"></div>
                    </div>
                </div>
                <button onclick="closeDetailModal()" class="text-white/70 hover:text-white transition-colors">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        </div>

        <!-- Body -->
        <div class="px-6 py-5 space-y-4 max-h-[65vh] overflow-y-auto">
            <!-- Info Grid -->
            <div class="grid grid-cols-2 gap-3">
                <div class="bg-slate-50 rounded-xl p-3">
                    <div class="text-xs text-slate-400 font-semibold uppercase tracking-wide">Fakultas</div>
                    <div class="text-sm font-bold text-slate-800 mt-1" id="d-fakultas"></div>
                </div>
                <div class="bg-slate-50 rounded-xl p-3">
                    <div class="text-xs text-slate-400 font-semibold uppercase tracking-wide">Tahun Lulus</div>
                    <div class="text-sm font-bold text-slate-800 mt-1" id="d-tahun"></div>
                </div>
                <div class="bg-slate-50 rounded-xl p-3">
                    <div class="text-xs text-slate-400 font-semibold uppercase tracking-wide">Kampus</div>
                    <div class="text-sm font-bold text-slate-800 mt-1" id="d-kampus"></div>
                </div>
                <div class="bg-slate-50 rounded-xl p-3">
                    <div class="text-xs text-slate-400 font-semibold uppercase tracking-wide">Status</div>
                    <div class="mt-1" id="d-status"></div>
                </div>
            </div>

            <!-- Kontak Pribadi -->
            <div class="bg-slate-50 rounded-xl p-4 space-y-2">
                <div class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-2">📞 Kontak Pribadi</div>
                <div class="grid grid-cols-2 gap-2">
                    <div><span class="text-xs text-slate-400">Email</span><div class="text-sm font-medium text-slate-800 break-all" id="d-email">-</div></div>
                    <div><span class="text-xs text-slate-400">No. HP</span><div class="text-sm font-medium text-slate-800" id="d-noHp">-</div></div>
                </div>
            </div>

            <!-- Sosial Media -->
            <div class="bg-slate-50 rounded-xl p-4">
                <div class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-3">🌐 Sosial Media Pribadi</div>
                <div id="d-sosmed" class="grid grid-cols-2 gap-2"></div>
            </div>

            <!-- Informasi Pekerjaan -->
            <div class="bg-slate-50 rounded-xl p-4 space-y-2">
                <div class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-2">💼 Pekerjaan</div>
                <div class="grid grid-cols-2 gap-2">
                    <div><span class="text-xs text-slate-400">Tempat Kerja</span><div class="text-sm font-bold text-slate-800" id="d-tempatKerja">-</div></div>
                    <div><span class="text-xs text-slate-400">Posisi</span><div class="text-sm font-bold text-slate-800" id="d-posisi">-</div></div>
                    <div><span class="text-xs text-slate-400">Jenis Pekerjaan</span><div class="text-sm font-bold text-slate-800" id="d-jenisPekerjaan">-</div></div>
                    <div><span class="text-xs text-slate-400">Alamat Kerja</span><div class="text-sm font-medium text-slate-800" id="d-alamatKerja">-</div></div>
                </div>
                <div class="mt-2"><span class="text-xs text-slate-400">Sosmed Tempat Kerja</span><div class="text-sm font-medium text-indigo-600 break-all" id="d-sosmedTempatKerja">-</div></div>
            </div>

            <!-- Confidence Bar -->
            <div class="bg-slate-50 rounded-xl p-4">
                <div class="flex justify-between items-center mb-2">
                    <span class="text-xs font-bold text-slate-500 uppercase tracking-wide">Tingkat Keyakinan</span>
                    <span class="text-sm font-bold text-indigo-600" id="d-score-text"></span>
                </div>
                <div class="w-full bg-slate-200 rounded-full h-2">
                    <div id="d-score-bar" class="h-2 rounded-full transition-all duration-700" style="width:0%"></div>
                </div>
            </div>

            <!-- Riwayat / Jejak -->
            <div class="bg-slate-50 rounded-xl p-4">
                <div class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-3">📋 Riwayat & Jejak Digital</div>
                <div id="d-jejak" class="space-y-2"></div>
            </div>
        </div>

        <!-- Footer -->
        <div class="border-t border-slate-100 px-6 py-4 flex justify-between items-center bg-slate-50/50">
            <a id="d-edit-link" href="#" class="text-sm font-semibold text-indigo-600 hover:text-indigo-800 transition-colors">✏️ Edit Data</a>
            <button onclick="closeDetailModal()" class="px-4 py-2 bg-slate-200 hover:bg-slate-300 text-slate-700 text-sm font-semibold rounded-lg transition-colors">Tutup</button>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->

<div id="deleteModal" class="hidden fixed inset-0 z-[100] overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <!-- Background overlay -->
        <div class="fixed inset-0 bg-slate-900/40 transition-opacity backdrop-blur-sm" aria-hidden="true" onclick="closeDeleteModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        <!-- Modal panel -->
        <div class="inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-md sm:w-full border border-slate-100">
            <div class="bg-white px-4 pt-6 pb-5 sm:p-8 sm:pb-6">
                <div class="sm:flex sm:items-start">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-14 w-14 rounded-full bg-rose-100 sm:mx-0 sm:h-12 sm:w-12 border border-rose-200 shadow-sm">
                        <svg class="h-6 w-6 text-rose-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    </div>
                    <div class="mt-4 text-center sm:mt-0 sm:ml-5 sm:text-left">
                        <h3 class="text-xl leading-6 font-bold text-slate-900 font-outfit" id="modal-title">Hapus Data Master</h3>
                        <div class="mt-3">
                            <p class="text-sm text-slate-500 leading-relaxed">
                                Apakah kamu yakin ingin menghapus alumni <strong id="delete-alumni-name" class="text-slate-800 font-bold bg-slate-100 px-1 rounded"></strong>?<br>Data ini akan terhapus secara permanen dari sistem database.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-slate-50/80 px-4 py-4 sm:px-8 sm:flex sm:flex-row-reverse border-t border-slate-100">
                <a id="btn-confirm-delete" href="#" class="w-full inline-flex justify-center rounded-xl border border-transparent shadow-sm shadow-rose-200 px-5 py-2.5 bg-rose-600 text-sm font-semibold text-white hover:bg-rose-700 focus:outline-none transition-all duration-200 sm:ml-3 sm:w-auto">
                    Ya, Hapus Data
                </a>
                <button type="button" onclick="closeDeleteModal()" class="mt-3 w-full inline-flex justify-center rounded-xl border border-slate-300 shadow-sm px-5 py-2.5 bg-white text-sm font-semibold text-slate-700 hover:bg-slate-50 focus:outline-none transition-all duration-200 sm:mt-0 sm:ml-3 sm:w-auto">
                    Batal
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // ── Delete Modal ──────────────────────────────
    function openDeleteModal(id, nama) {
        document.getElementById('delete-alumni-name').textContent = nama;
        document.getElementById('btn-confirm-delete').href = '/delete/' + id;
        document.getElementById('deleteModal').classList.remove('hidden');
    }
    function closeDeleteModal() {
        document.getElementById('deleteModal').classList.add('hidden');
    }

    // ── Detail Modal ──────────────────────────────
    function openDetailModal(alumni) {
        document.getElementById('d-avatar').textContent = alumni.namaLengkap.charAt(0).toUpperCase();
        document.getElementById('d-nama').textContent = alumni.namaLengkap;
        document.getElementById('d-prodi').textContent = (alumni.nim ? alumni.nim + ' • ' : '') + (alumni.prodi || '-');
        document.getElementById('d-fakultas').textContent = alumni.fakultas || '-';
        document.getElementById('d-tahun').textContent = alumni.tahunLulus || '-';
        document.getElementById('d-kampus').textContent = alumni.kampus || '-';
        document.getElementById('d-edit-link').href = '/edit/' + alumni.id;

        // Kontak
        document.getElementById('d-email').textContent  = alumni.email  || '-';
        document.getElementById('d-noHp').textContent   = alumni.noHp   || '-';

        // Sosial Media Pribadi
        const sosmedList = [
            { label: '💼 LinkedIn',  val: alumni.linkedin  },
            { label: '📸 Instagram', val: alumni.instagram },
            { label: '👤 Facebook',  val: alumni.facebook  },
            { label: '🎵 TikTok',   val: alumni.tiktok    },
        ];
        document.getElementById('d-sosmed').innerHTML = sosmedList.map(s =>
            `<div><span class="text-xs text-slate-400">${s.label}</span><div class="text-sm font-medium text-indigo-600 break-all">${s.val || '-'}</div></div>`
        ).join('');

        // Pekerjaan
        document.getElementById('d-tempatKerja').textContent      = alumni.tempatKerja      || '-';
        document.getElementById('d-posisi').textContent           = alumni.posisi           || '-';
        document.getElementById('d-jenisPekerjaan').textContent   = alumni.jenisPekerjaan   || '-';
        document.getElementById('d-alamatKerja').textContent      = alumni.alamatKerja      || '-';
        document.getElementById('d-sosmedTempatKerja').textContent = alumni.sosmedTempatKerja || '-';

        // Status badge
        const score = alumni.confidenceScore || 0;
        const statusColors = score >= 70
            ? 'bg-emerald-100 text-emerald-700 border-emerald-200'
            : score >= 40
            ? 'bg-amber-100 text-amber-700 border-amber-200'
            : 'bg-rose-100 text-rose-700 border-rose-200';
        document.getElementById('d-status').innerHTML =
            `<span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold border ${statusColors}">${alumni.status}</span>`;

        // Confidence bar
        const barColor = score >= 70 ? 'bg-emerald-500' : score >= 40 ? 'bg-amber-500' : 'bg-rose-500';
        document.getElementById('d-score-text').textContent = score + '%';
        const bar = document.getElementById('d-score-bar');
        bar.className = `h-2 rounded-full transition-all duration-700 ${barColor}`;
        bar.style.width = '0%';
        setTimeout(() => { bar.style.width = score + '%'; }, 80);

        // Jejak
        const jejak = alumni.jejak || 'Belum ada catatan riwayat.';
        const items = jejak.split(' | ').filter(Boolean);
        document.getElementById('d-jejak').innerHTML = items.map(item => {
            const isLinkedIn = item.toLowerCase().includes('linkedin');
            const isGithub   = item.toLowerCase().includes('github');
            const isScholar  = item.toLowerCase().includes('scholar');
            const icon = isLinkedIn ? '💼' : isGithub ? '💻' : isScholar ? '📄' : '📍';
            return `<div class="flex items-start gap-2 text-sm text-slate-700 bg-white rounded-lg px-3 py-2 border border-slate-100 leading-relaxed">
                <span class="mt-0.5 flex-shrink-0">${icon}</span>
                <span>${item}</span>
            </div>`;
        }).join('');

        document.getElementById('detailModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeDetailModal() {
        document.getElementById('detailModal').classList.add('hidden');
        document.body.style.overflow = '';
        document.getElementById('d-score-bar').style.width = '0%';
    }


    // ── Keyboard shortcuts ────────────────────────
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') { closeDetailModal(); closeDeleteModal(); }
    });

    // ── Toast Notification ────────────────────────────────────
    const ALERTS = {
        'add-success':    { title: 'Data Ditambahkan!',    msg: 'Alumni baru berhasil disimpan ke database.', color: 'emerald' },
        'edit-success':   { title: 'Data Diperbarui!',     msg: 'Perubahan data alumni berhasil disimpan.', color: 'emerald' },
        'delete-success': { title: 'Data Dihapus',         msg: 'Data alumni berhasil dihapus dari sistem.', color: 'rose' },
        'bot-success':    { title: 'Pelacakan Berhasil!',  msg: 'Data alumni baru ditambahkan.', color: 'emerald' },
        'bot-exist':      { title: 'Pelacakan Selesai',    msg: 'Sistem tidak menemukan sumber baru di publik.', color: 'amber' },
    };
    window.addEventListener('load', function() {
        const urlParams = new URLSearchParams(window.location.search);
        const alertType = urlParams.get('alert');
        const cfg = ALERTS[alertType];
        if (!cfg) return;

        const toast = document.getElementById('toast-success');
        const iconBg = document.getElementById('toast-icon-bg');
        const c = cfg.color;
        iconBg.className = `inline-flex items-center justify-center flex-shrink-0 w-10 h-10 text-${c}-600 bg-${c}-100/80 rounded-xl border border-${c}-200 shadow-sm`;
        document.getElementById('toast-title').textContent  = cfg.title;
        document.getElementById('toast-message').textContent = cfg.msg;

        toast.classList.remove('hidden');
        setTimeout(() => toast.classList.remove('opacity-0'), 100);
        setTimeout(() => {
            toast.classList.add('opacity-0');
            setTimeout(() => toast.classList.add('hidden'), 500);
        }, 4000);
        window.history.replaceState({}, document.title, '/data');
    });

    // ── Search: Debounce + Server-side Submit ─────────────────────────────────
    // Kenapa debounce? Untuk data 100k+, setiap keystroke = 1 query Supabase.
    // Debounce 400ms mencegah spam query saat user masih mengetik.
    const searchInput  = document.getElementById('searchInput');
    const clearBtn     = document.getElementById('clearSearch');
    const searchIcon   = document.getElementById('search-icon');
    const searchSpinner= document.getElementById('search-spinner');
    const tahunFilter  = document.getElementById('tahunFilter');
    const jenisFilter  = document.getElementById('jenisFilter');
    let debounceTimer  = null;

    // Helper: submit form dengan reset ke halaman 1
    function submitFilters() {
        // Hapus parameter page agar mulai dari halaman 1 setiap kali filter berubah
        const form = document.getElementById('searchForm');
        const existingPage = form.querySelector('input[name="page"]');
        if (existingPage) existingPage.remove();
        // Tampilkan spinner
        searchIcon.classList.add('hidden');
        searchSpinner.classList.remove('hidden');
        form.submit();
    }

    // Debounce: tunggu 400ms setelah ketikan terakhir sebelum submit
    searchInput.addEventListener('input', function () {
        // Tampilkan/sembunyikan tombol clear
        clearBtn.classList.toggle('hidden', !this.value);

        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(submitFilters, 400);
    });

    // Enter key → submit langsung tanpa menunggu debounce
    searchInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') {
            clearTimeout(debounceTimer);
            submitFilters();
        }
    });

    // Tombol X: hapus search & submit
    clearBtn.addEventListener('click', function () {
        searchInput.value = '';
        this.classList.add('hidden');
        clearTimeout(debounceTimer);
        submitFilters();
    });

    // Filter dropdown: langsung submit saat berubah (tidak perlu debounce)
    tahunFilter.addEventListener('change', () => {
        clearTimeout(debounceTimer);
        submitFilters();
    });
    jenisFilter.addEventListener('change', () => {
        clearTimeout(debounceTimer);
        submitFilters();
    });

    // Focus search saat halaman dimuat (UX)
    // Hanya jika tidak ada modal/toast yang terbuka
    if (!document.querySelector('.modal-open')) {
        searchInput.focus({ preventScroll: true });
    }
</script>

<%- include('partials/footer') %>
